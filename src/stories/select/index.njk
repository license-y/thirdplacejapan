---
title: "TPJセレクト ― 気になる居場所たち"
description: "Third Place Japan編集部がセレクトした、日本全国のサードプレイス。有名・無名を問わず、居場所としての価値で選んでいます。"
canonical: "/stories/select/"
---

{# BreadcrumbList JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Third Place Japan", "item": "{{ site.url }}" },
    { "@type": "ListItem", "position": 2, "name": "Stories", "item": "{{ site.url }}/stories/" },
    { "@type": "ListItem", "position": 3, "name": "TPJセレクト", "item": "{{ site.url }}/stories/select/" }
  ]
}
</script>

{# JSON-LD: ItemList #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Third Place Japan TPJセレクト一覧",
  "description": "Third Place Japan編集部がセレクトした居場所リスト",
  "url": "{{ site.url }}/stories/select/",
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}/stories/select/"
  },
  "numberOfItems": {{ venues | publishedVenues | length }},
  "itemListElement": [
    {% set published = venues | publishedVenues %}
    {% for v in published %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "name": {{ v.name | dump | safe }},
      "description": "{{ v.grade }} / {{ v.category }} / {{ v.area_primary.prefecture }}{{ v.area_primary.area }}",
      "url": "{{ site.url }}/stories/select/{{ v.slug }}/"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

{# FAQPage JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "TPJセレクトとはどのような施設ですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "TPJセレクトとは、Third Place Japan（サードプレイスジャパン）編集部が独自の視点で見つけた「いま気になる居場所」です。料理ではなく「いる体験・居場所としての価値」を軸に、カフェ・ホテル・スパ・コワーキングなど業種横断で紹介しています。"
      }
    },
    {
      "@type": "Question",
      "name": "TPJセレクトのグレードにはどんな種類がありますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "TPJセレクトはCertified・Standard・Silver・Gold・Flagshipの5段階グレード制です。Flagshipが最高グレードで、7つの空間基準すべてにおいて卓越した体験を提供する施設に与えられます。"
      }
    },
    {
      "@type": "Question",
      "name": "TPJセレクトをエリアや業種で絞り込めますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "はい。掲載施設は都道府県・市区町村・エリアの3階層と、15業種（カフェ・ホテル・スパ・コワーキング等）で絞り込んで探せます。{{ site.url }}/stories/area/からエリア検索、{{ site.url }}/stories/から業種別に閲覧できます。"
      }
    }
  ]
}
</script>

{% set published = venues | publishedVenues %}
{% set flagshipVenues = venues | venuesByGrade('flagship') %}
{% set selectCount = published.length - flagshipVenues.length %}

<div class="max-w-6xl mx-auto px-6 py-24">

  <nav class="flex items-center gap-2 text-xs text-muted mb-12">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span>／</span>
    <span>TPJセレクト</span>
  </nav>

  <div class="mb-16" data-aos="fade-up">
    <p class="label mb-4">TPJ Select</p>
    <h1 class="font-serif text-4xl font-light text-dark mb-4">TPJセレクト ― 気になる居場所たち</h1>
    <div class="gold-rule mb-6"></div>
    <p class="text-sm text-muted max-w-xl text-left md:text-center md:mx-auto">
      TPJ編集部が、いまいたいと思う場所。<br class="hidden md:block">
      有名・無名を問わず、居場所としての価値で選んでいます。
    </p>
  </div>

  {# ── Flagship セクション（GBC単独・最上部固定枠） ── #}
  {% if flagshipVenues.length %}
  <section class="mb-20" data-aos="fade-up">
    <div class="flex items-center gap-3 mb-2 pb-4 border-b border-gold/40">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gold shrink-0" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
      <p class="label">Flagship</p>
    </div>
    <p class="text-xs text-muted mb-8">Third Place Japanが提唱する理想の空間を体現する旗艦店</p>
    {% for v in flagshipVenues %}
    <a href="/stories/select/{{ v.slug }}/"
       class="flex flex-col md:flex-row gap-6 bg-white border-2 border-gold/60 hover:border-gold rounded-2xl p-8 shadow-md hover:shadow-xl transition-all group">
      <div class="flex-1 min-w-0">
        <div class="flex items-center gap-2 mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-gold shrink-0" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
          <span class="text-xs font-medium tracking-widest text-gold uppercase">Flagship</span>
          <span class="text-xs text-muted border border-border rounded-full px-2 py-0.5 ml-2">{{ v.category }}</span>
        </div>
        <h2 class="font-serif text-2xl md:text-3xl font-light text-dark mb-2 group-hover:text-gold transition-colors">
          {{ v.name }}
        </h2>
        <p class="text-xs text-muted mb-5">
          {{ v.area_primary.prefecture }} {{ v.area_primary.area }}
          {% if v.nearest_stations and v.nearest_stations.length %}
           ／ {{ v.nearest_stations | join("・") }}
          {% endif %}
        </p>
        <p class="text-sm text-text leading-relaxed mb-6">{{ v.citation }}</p>
        <div class="flex flex-wrap gap-2">
          <span class="text-xs text-gold border border-gold px-3 py-0.5 rounded-full">{{ v.axes_primary }}</span>
          {% for ax in v.axes_secondary %}
          <span class="text-xs text-muted border border-border px-3 py-0.5 rounded-full">{{ ax }}</span>
          {% endfor %}
        </div>
      </div>
    </a>
    {% endfor %}
  </section>
  {% endif %}

  {# ── TPJセレクト セクション（その他実店舗一覧） ── #}
  {% if selectCount > 0 %}
  <section class="mb-16" data-aos="fade-up">
    <div class="flex items-center justify-between mb-2 pb-4 border-b border-border">
      <div class="flex items-center gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted shrink-0" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        <p class="label">TPJセレクト</p>
      </div>
      <span class="text-xs text-muted border border-border rounded-full px-3 py-1">随時追加中：現在{{ selectCount }}件</span>
    </div>
    <p class="text-xs text-muted mb-8">TPJ編集部が、いまいたいと思う場所。</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for v in published | reverse %}
      {% if v.grade_slug != 'flagship' %}
      <a href="/stories/select/{{ v.slug }}/"
         class="venue-card block p-4 md:p-6 bg-white rounded-xl shadow-sm hover:shadow-md transition-all group">
        <div class="flex items-start justify-between mb-3">
          <div class="flex items-center gap-1.5 text-xs text-muted border border-border rounded-full px-2.5 py-0.5">
            <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
            TPJセレクト
          </div>
          <span class="label text-xs">{{ v.category }}</span>
        </div>
        <h3 class="font-serif text-lg font-light text-dark mb-1.5 group-hover:text-gold transition-colors">
          {{ v.name }}
        </h3>
        <p class="text-xs text-muted mb-3">
          {{ v.area_primary.prefecture }} {{ v.area_primary.area }}
        </p>
        <p class="text-sm text-text leading-relaxed line-clamp-3">{{ v.citation }}</p>
        <div class="mt-3 flex flex-wrap gap-1.5">
          <span class="text-xs text-gold border border-gold px-3 py-0.5 rounded-full">{{ v.axes_primary }}</span>
          {% for ax in v.axes_secondary %}
          <span class="text-xs text-muted border border-border px-3 py-0.5 rounded-full">{{ ax }}</span>
          {% endfor %}
        </div>
      </a>
      {% endif %}
      {% endfor %}
    </div>
    {# グレード凡例（下部） #}
    <div class="flex flex-wrap gap-2 items-center mt-10 pt-6 border-t border-border">
      <span class="text-xs text-muted mr-1">認証グレード：</span>
      <span class="text-xs font-medium tracking-wider px-2.5 py-0.5 rounded-full border" style="color:#8B8378;border-color:#8B8378;">Certified</span>
      <span class="text-xs font-medium tracking-wider px-2.5 py-0.5 rounded-full border" style="color:#9AA0A6;border-color:#9AA0A6;">Silver</span>
      <span class="text-xs font-medium tracking-wider text-gold border border-gold px-2.5 py-0.5 rounded-full">Gold</span>
      <span class="text-xs font-medium tracking-wider px-2.5 py-0.5 rounded-full border" style="color:#4A4A4A;border-color:#4A4A4A;">Platinum</span>
      <span class="inline-flex items-center gap-1.5 text-xs font-medium tracking-wider px-2.5 py-0.5 rounded-full border-2" style="color:#1C1C1C;border-color:#1C1C1C;">
        <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
        Flagship
      </span>
      <a href="/stories/about/certification-grades/" class="text-xs text-muted hover:text-gold transition-colors ml-auto underline underline-offset-2">グレードの違いを見る →</a>
    </div>
  </section>
  {% endif %}

</div>

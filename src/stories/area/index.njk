{# FAQPage JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "エリアごとにTPJ認証のサードプレイスを探せますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "はい。Third Place Japanでは都道府県・市区町村・エリアの3階層でセレクト店舗を探せます。現在は東京都内を中心に、渋谷・中目黒・青山などエリア単位での絞り込みが可能で、今後は他の都市へも順次展開予定です。"
      }
    },
    {
      "@type": "Question",
      "name": "東京でTPJ認証を受けたサードプレイスはどこで探せますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "東京のTPJセレクト店舗は{{ site.url }}/stories/area/tokyo/から探せます。渋谷・港区・新宿区など区ごとにさらに絞り込み、カフェ・スパ・コワーキングなど業種でのフィルタリングも可能です。"
      }
    }
  ]
}
</script>

<div class="max-w-6xl mx-auto px-6 py-24">

  <nav class="flex items-center gap-2 text-xs text-muted mb-12">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span>／</span>
    <span>場所をめぐる</span>
  </nav>

  <div class="mb-16" data-aos="fade-up">
    <p class="label mb-4">場所をめぐる</p>
    <h1 class="font-serif text-4xl font-light text-dark mb-4">エリアから探す</h1>
    <div class="gold-rule"></div>
  </div>

  <div class="space-y-12" data-aos="fade-up">
    {% for pref in areas %}
    <div>
      <!-- 都道府県 -->
      <div class="flex items-center justify-between mb-6 pb-3 border-b border-border">
        <a href="/stories/area/{{ pref.slug }}/"
           class="inline-flex items-center gap-2 font-serif text-2xl font-light text-dark hover:text-gold transition-colors group">
          {{ pref.name }}
          <i data-lucide="arrow-right" class="w-4 h-4 text-gold opacity-50 group-hover:opacity-100 group-hover:translate-x-0.5 transition-all"></i>
        </a>
        <a href="/stories/area/{{ pref.slug }}/"
           class="text-xs text-muted hover:text-gold transition-colors shrink-0 ml-4">
          すべて見る →
        </a>
      </div>
      <div class="space-y-5">
        {% for city in pref.cities %}
        <div>
          <!-- 市区町村 -->
          <a href="/stories/area/{{ pref.slug }}/{{ city.slug }}/"
             class="inline-flex items-center gap-1.5 text-sm font-medium text-dark bg-white border border-gold/40 rounded-lg px-3 py-1.5 mb-3 shadow-sm hover:border-gold hover:text-gold hover:shadow-md transition-all group">
            {{ city.name }}
            <i data-lucide="chevron-right" class="w-3.5 h-3.5 text-muted group-hover:text-gold transition-colors"></i>
          </a>
          {% if city.areas and city.areas.length %}
          <div class="flex flex-wrap gap-2">
            {% for area in city.areas %}
            <a href="/stories/area/{{ pref.slug }}/{{ city.slug }}/{{ area.slug }}/"
               class="text-xs border border-border rounded-full px-3 py-1 hover:border-gold hover:text-gold transition-colors">
              {{ area.name }}
            </a>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </div>
    {% endfor %}
  </div>

  <!-- エリア拡大中バナー -->
  <div class="mt-16 border border-gold/40 rounded-xl px-8 py-6 text-center" data-aos="fade-up">
    <p class="label mb-3">Coming Soon</p>
    <p class="font-serif text-lg font-light text-dark mb-2">全国エリア順次公開中</p>
    <p class="text-xs text-muted leading-relaxed">
      大阪・京都・神奈川・福岡など、主要エリアを順次追加予定です。<br class="hidden md:block">
      引き続き東京都内エリアの充実を進めながら、全国展開を目指しています。
    </p>
  </div>

</div>

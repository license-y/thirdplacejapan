---
pagination:
  data: areaL3
  size: 1
  alias: item
permalink: "/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ item.area.slug }}/"
layout: area.njk
---
{# FAQPage JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "{{ item.area.name }}でサードプレイスとして認証された場所はどこですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Third Place Japanが{{ item.area.name }}で認証した場所として、{% set av = venues | venuesByArea(item.prefecture.slug, item.city.slug, item.area.slug) %}{% for v in av %}{{ v.name }}（{{ v.grade }}）{% if not loop.last %}、{% endif %}{% endfor %}があります。"
      }
    },
    {
      "@type": "Question",
      "name": "{{ item.area.name }}のサードプレイスの特徴は何ですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.area.name }}（{{ item.city.name }}・{{ item.prefecture.name }}）のサードプレイスは、エリアの街の性格を反映した独自の居場所文化を持っています。Third Place Japanでは居心地・静寂性・特別感など7軸で評価し、「ただいる」ことができる場所を認証しています。"
      }
    },
    {
      "@type": "Question",
      "name": "{{ item.area.name }}ではどんな業種のサードプレイスが見つかりますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.area.name }}ではカフェ・スペシャルティコーヒー、ホテルラウンジ、コワーキングスペース、神社・寺院など複数の業種にわたるサードプレイスが存在します。Third Place Japanは業種横断で「居場所としての価値」を評価・認証しています。"
      }
    }
  ]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Stories", "item": "{{ site.url }}/stories/" },
    { "@type": "ListItem", "position": 2, "name": "{{ item.prefecture.name }}", "item": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/" },
    { "@type": "ListItem", "position": 3, "name": "{{ item.city.name }}", "item": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/" },
    { "@type": "ListItem", "position": 4, "name": "{{ item.area.name }}", "item": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ item.area.slug }}/" }
  ]
}
</script>

{% if item.area.slug == 'sendagaya' and item.city.slug == 'shibuya-ku' %}
{# ── 試験的実装：千駄ヶ谷のみ2カラム＋Googleマップ ── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Place",
  "name": "{{ item.area.name }}",
  "description": "{{ item.area.name }}（{{ item.city.name }}・{{ item.prefecture.name }}）のサードプレイス認証エリア。Third Place Japanが7軸基準で認証した施設を掲載。",
  "url": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ item.area.slug }}/",
  "containedInPlace": {
    "@type": "AdministrativeArea",
    "name": "{{ item.city.name }}",
    "containedInPlace": { "@type": "AdministrativeArea", "name": "{{ item.prefecture.name }}" }
  },
  "hasMap": "https://www.google.com/maps/search/{{ item.area.name }}+{{ item.city.name }}+{{ item.prefecture.name }}"
}
</script>

<div class="max-w-6xl mx-auto px-6 py-24">
  <nav class="flex items-center flex-wrap gap-2 text-xs text-muted mb-12">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span>/</span>
    <a href="/stories/area/{{ item.prefecture.slug }}/" class="hover:text-gold transition-colors">{{ item.prefecture.name }}</a>
    <span>/</span>
    <a href="/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/" class="hover:text-gold transition-colors">{{ item.city.name }}</a>
    <span>/</span>
    <span>{{ item.area.name }}</span>
  </nav>
  <div class="mb-12" data-aos="fade-up">
    <p class="label mb-4">{{ item.prefecture.name }} {{ item.city.name }}</p>
    <h1 class="font-serif text-4xl font-light text-dark mb-4">{{ item.area.name }}のサードプレイス</h1>
    <div class="gold-rule mb-6"></div>
    <p class="text-sm text-muted">{{ item.area.name }}エリアで Third Place Japan が認証した場所。</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 items-start">
    {# メインコンテンツ #}
    <div class="lg:col-span-2">
      {% set areaArticles = collections.articles | articlesByArea(item.area.slug) %}
      {% if areaArticles.length %}
      <section class="mb-12" data-aos="fade-up">
        <p class="label mb-6">{{ item.area.name }}の関連記事</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {% for post in areaArticles %}
          <a href="{{ post.url }}" class="group block rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow bg-white">
            {% if post.data.thumbnail %}
            <div class="aspect-video overflow-hidden">
              <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" decoding="async">
            </div>
            {% endif %}
            <div class="p-4">
              <p class="text-xs text-muted mb-2">{{ post.date | dateJa }}</p>
              <p class="text-sm font-medium text-dark leading-snug group-hover:text-gold transition-colors">{{ post.data.title }}</p>
            </div>
          </a>
          {% endfor %}
        </div>
      </section>
      {% endif %}
      {% if areaL3Cat %}
      <section class="mb-12" data-aos="fade-up">
        <p class="label mb-4">業種から探す</p>
        <div class="flex flex-wrap gap-3">
          {% for cat in areaL3Cat %}
          {% if cat.area.slug == item.area.slug and cat.prefecture.slug == item.prefecture.slug %}
          <a href="/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ item.area.slug }}/{{ cat.category.slug }}/"
             class="text-xs border border-border px-4 py-2 hover:border-gold hover:text-gold transition-colors">
            {{ cat.category.name_ja }}
          </a>
          {% endif %}
          {% endfor %}
        </div>
      </section>
      {% endif %}
      {% set areaVenues = venues | venuesByArea(item.prefecture.slug, item.city.slug, item.area.slug) %}
      {% if areaVenues.length %}
      <section data-aos="fade-up">
        <p class="label mb-6">認証店舗</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {% for v in areaVenues | sortByGrade %}
          {% set cardVenue = v %}{% include "venue-card.njk" %}
          {% endfor %}
        </div>
      </section>
      {% else %}
      <p class="text-sm text-muted" data-aos="fade-up">このエリアの認証店舗は準備中です。</p>
      {% endif %}
    </div>

    {# サイドバー #}
    <aside class="lg:col-span-1 space-y-8 lg:sticky lg:top-24" data-aos="fade-up">
      <div>
        <p class="label mb-3">{{ item.area.name }}のマップ</p>
        <div class="overflow-hidden border border-border">
          <iframe
            title="{{ item.area.name }}のGoogleマップ"
            src="https://maps.google.com/maps?q={{ item.area.name }}+{{ item.city.name }}+{{ item.prefecture.name }}&output=embed&hl=ja&z=15"
            width="100%" height="260" style="border:0;display:block"
            loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
        <a href="https://www.google.com/maps/search/{{ item.area.name }}+{{ item.city.name }}+{{ item.prefecture.name }}"
           target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-1 mt-2 text-xs hover:text-gold transition-colors" style="color:var(--color-muted)">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Googleマップで{{ item.area.name }}を開く
        </a>
      </div>
      <div>
        <p class="label mb-3">{{ item.city.name }}のマップ</p>
        <div class="overflow-hidden border border-border">
          <iframe
            title="{{ item.city.name }}のGoogleマップ"
            src="https://maps.google.com/maps?q={{ item.city.name }}+{{ item.prefecture.name }}&output=embed&hl=ja&z=13"
            width="100%" height="220" style="border:0;display:block"
            loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
        <a href="/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/"
           class="flex items-center gap-1 mt-2 text-xs hover:text-gold transition-colors" style="color:var(--color-muted)">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          {{ item.city.name }}の全エリアへ
        </a>
      </div>
      <div class="border-t border-border pt-6">
        <p class="text-xs leading-relaxed" style="color:var(--color-muted)">
          Third Place Japanは{{ item.area.name }}の認証施設情報を独自の7軸基準で評価・掲載しています。
        </p>
      </div>
    </aside>
  </div>
</div>

{% else %}
{# ── 通常レイアウト ── #}
<div class="max-w-6xl mx-auto px-6 py-24">
  <nav class="flex items-center flex-wrap gap-2 text-xs text-muted mb-12">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span>/</span>
    <a href="/stories/area/{{ item.prefecture.slug }}/" class="hover:text-gold transition-colors">{{ item.prefecture.name }}</a>
    <span>/</span>
    <a href="/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/" class="hover:text-gold transition-colors">{{ item.city.name }}</a>
    <span>/</span>
    <span>{{ item.area.name }}</span>
  </nav>
  <div class="mb-16" data-aos="fade-up">
    <p class="label mb-4">{{ item.prefecture.name }} {{ item.city.name }}</p>
    <h1 class="font-serif text-4xl font-light text-dark mb-4">{{ item.area.name }}のサードプレイス</h1>
    <div class="gold-rule mb-6"></div>
    <p class="text-sm text-muted">{{ item.area.name }}エリアで Third Place Japan が認証した場所。</p>
  </div>
  {% set areaArticles = collections.articles | articlesByArea(item.area.slug) %}
  {% if areaArticles.length %}
  <section class="mb-12" data-aos="fade-up">
    <p class="label mb-6">{{ item.area.name }}の関連記事</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for post in areaArticles %}
      <a href="{{ post.url }}" class="group block rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow bg-white">
        {% if post.data.thumbnail %}
        <div class="aspect-video overflow-hidden">
          <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" decoding="async">
        </div>
        {% endif %}
        <div class="p-4">
          <p class="text-xs text-muted mb-2">{{ post.date | dateJa }}</p>
          <p class="text-sm font-medium text-dark leading-snug group-hover:text-gold transition-colors">{{ post.data.title }}</p>
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}
  {% if areaL3Cat %}
  <section class="mb-12" data-aos="fade-up">
    <p class="label mb-4">業種から探す</p>
    <div class="flex flex-wrap gap-3">
      {% for cat in areaL3Cat %}
      {% if cat.area.slug == item.area.slug and cat.prefecture.slug == item.prefecture.slug %}
      <a href="/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ item.area.slug }}/{{ cat.category.slug }}/"
         class="text-xs border border-border px-4 py-2 hover:border-gold hover:text-gold transition-colors">
        {{ cat.category.name_ja }}
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </section>
  {% endif %}
  {% set areaVenues = venues | venuesByArea(item.prefecture.slug, item.city.slug, item.area.slug) %}
  {% if areaVenues.length %}
  <section data-aos="fade-up">
    <p class="label mb-6">認証店舗</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for v in areaVenues | sortByGrade %}
      {% set cardVenue = v %}{% include "venue-card.njk" %}
      {% endfor %}
    </div>
  </section>
  {% else %}
  <p class="text-sm text-muted" data-aos="fade-up">このエリアの認証店舗は準備中です。</p>
  {% endif %}

  {# FAQ セクション #}
  <section class="mt-16 pt-10 border-t border-border" data-aos="fade-up">
    <div class="flex items-center gap-3 mb-6">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted shrink-0" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
      <h2 class="font-serif text-xl font-light text-dark">よくある質問</h2>
    </div>
    <div class="space-y-3">
      <div class="bg-white border border-gold/30 rounded-xl overflow-hidden shadow-sm">
        <button class="area-faq-btn w-full flex items-center justify-between px-6 py-4 text-left gap-4" aria-expanded="true">
          <span class="font-serif text-sm font-light text-dark leading-snug">{{ item.area.name }}でサードプレイスとして認証された場所はどこですか？</span>
          <i data-lucide="chevron-down" class="w-4 h-4 text-muted shrink-0 transition-transform duration-300" style="transform:rotate(180deg)"></i>
        </button>
        <div class="area-faq-body px-6 pb-5">
          <div class="gold-rule mb-4"></div>
          {% set av = venues | venuesByArea(item.prefecture.slug, item.city.slug, item.area.slug) %}
          {% if av.length %}
          <p class="text-sm text-muted leading-relaxed">Third Place Japanが{{ item.area.name }}で認証した場所として、{% for v in av %}<a href="/stories/certified/{{ v.slug }}/" class="text-gold hover:underline">{{ v.name }}</a>（{{ v.grade }}）{% if not loop.last %}、{% endif %}{% endfor %}があります。</p>
          {% else %}
          <p class="text-sm text-muted leading-relaxed">{{ item.area.name }}の認証店舗は現在準備中です。Third Place Japanは順次エリアを拡大しています。</p>
          {% endif %}
        </div>
      </div>
      <div class="bg-white border border-gold/30 rounded-xl overflow-hidden shadow-sm">
        <button class="area-faq-btn w-full flex items-center justify-between px-6 py-4 text-left gap-4" aria-expanded="true">
          <span class="font-serif text-sm font-light text-dark leading-snug">{{ item.area.name }}のサードプレイスの特徴は何ですか？</span>
          <i data-lucide="chevron-down" class="w-4 h-4 text-muted shrink-0 transition-transform duration-300" style="transform:rotate(180deg)"></i>
        </button>
        <div class="area-faq-body px-6 pb-5">
          <div class="gold-rule mb-4"></div>
          <p class="text-sm text-muted leading-relaxed">{{ item.area.name }}（{{ item.city.name }}・{{ item.prefecture.name }}）のサードプレイスは、エリアの街の性格を反映した独自の居場所文化を持っています。Third Place Japanでは居心地・静寂性・特別感など7軸で評価し、「ただいる」ことができる場所を認証しています。</p>
        </div>
      </div>
      <div class="bg-white border border-gold/30 rounded-xl overflow-hidden shadow-sm">
        <button class="area-faq-btn w-full flex items-center justify-between px-6 py-4 text-left gap-4" aria-expanded="true">
          <span class="font-serif text-sm font-light text-dark leading-snug">{{ item.area.name }}ではどんな業種のサードプレイスが見つかりますか？</span>
          <i data-lucide="chevron-down" class="w-4 h-4 text-muted shrink-0 transition-transform duration-300" style="transform:rotate(180deg)"></i>
        </button>
        <div class="area-faq-body px-6 pb-5">
          <div class="gold-rule mb-4"></div>
          <p class="text-sm text-muted leading-relaxed">{{ item.area.name }}ではカフェ・スペシャルティコーヒー、ホテルラウンジ、コワーキングスペース、神社・寺院など複数の業種にわたるサードプレイスが存在します。Third Place Japanは業種横断で「居場所としての価値」を評価・認証しています。</p>
        </div>
      </div>
    </div>
    <script>
    document.querySelectorAll('.area-faq-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var body = this.nextElementSibling;
        var icon = this.querySelector('[data-lucide]');
        var isOpen = this.getAttribute('aria-expanded') === 'true';
        body.classList.toggle('hidden', isOpen);
        this.setAttribute('aria-expanded', !isOpen);
        if (icon) icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      });
    });
    </script>
  </section>
</div>
{% endif %}

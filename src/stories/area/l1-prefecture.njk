---
pagination:
  data: areas
  size: 1
  alias: prefecture
permalink: "/stories/area/{{ prefecture.slug }}/"
layout: area.njk
---
{# L1: 都道府県インデックス #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Stories", "item": "{{ site.url }}/stories/" },
    { "@type": "ListItem", "position": 2, "name": "場所をめぐる", "item": "{{ site.url }}/stories/area/" },
    { "@type": "ListItem", "position": 3, "name": "{{ prefecture.name }}", "item": "{{ site.url }}/stories/area/{{ prefecture.slug }}/" }
  ]
}
</script>

<div class="max-w-6xl mx-auto px-6 py-24">

  <nav class="flex items-center gap-2 text-xs text-muted mb-12">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span>/</span>
    <a href="/stories/area/" class="hover:text-gold transition-colors">場所をめぐる</a>
    <span>/</span>
    <span>{{ prefecture.name }}</span>
  </nav>

  <div class="mb-16" data-aos="fade-up">
    <p class="label mb-4">{{ prefecture.name }}</p>
    <h1 class="font-serif text-4xl font-light text-dark mb-4">
      {{ prefecture.name }}のサードプレイス
    </h1>
    <div class="gold-rule"></div>
  </div>

  {# 市区町村リスト #}
  <section class="mb-16" data-aos="fade-up">
    <p class="label mb-6">エリアから探す</p>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
      {% for city in prefecture.cities %}
      <a href="/stories/area/{{ prefecture.slug }}/{{ city.slug }}/"
         class="border border-border p-4 hover:border-gold hover:text-gold transition-colors group">
        <p class="font-serif text-base font-light group-hover:text-gold transition-colors">{{ city.name }}</p>
        {% set cityVenues = venues | venuesByArea(prefecture.slug, city.slug) %}
        {% if cityVenues.length %}
        <p class="text-xs text-muted mt-1">{{ cityVenues.length }}件の認証店舗</p>
        {% endif %}
      </a>
      {% endfor %}
    </div>
  </section>

  {# この都道府県の全認証店舗 #}
  {% set prefVenues = venues | venuesByArea(prefecture.slug) %}
  {% if prefVenues.length %}
  <section data-aos="fade-up">
    <p class="label mb-6">認証店舗</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for v in prefVenues | sortByGrade %}
      {% set cardVenue = v %}{% include "venue-card.njk" %}
      {% endfor %}
    </div>
  </section>
  {% endif %}

</div>

  var searchInput = document.getElementById('area-search');
  var searchClear = document.getElementById('search-clear');
  var searchHint  = document.getElementById('search-hint');
  var cityCards   = document.querySelectorAll('.city-card');
  var noResults   = document.getElementById('no-results');

  function normalize(str) {
    return (str || '').toLowerCase().replace(/[\s　]/g, '');
  }

  function filterCards(query) {
    var q = normalize(query);
    var visibleCount = 0;
    var hintParts = [];

    /* 駅名エイリアスでマッチした citySlug を収集 */
    var stationHits = {}; /* citySlug -> [{station, areaSlug, areaName, cityName}] */
    if (q.length >= 1) {
      Object.keys(STATION_ALIASES).forEach(function (station) {
        if (normalize(station).includes(q)) {
          var info = STATION_ALIASES[station];
          if (!stationHits[info.citySlug]) stationHits[info.citySlug] = [];
          stationHits[info.citySlug].push({
            station: station,
            areaSlug: info.areaSlug,
            areaName: info.areaName,
            cityName: info.cityName
          });
        }
      });
    }

    cityCards.forEach(function (card) {
      var cityName  = card.dataset.cityName  || '';
      var citySlug  = card.dataset.citySlug  || '';
      var areasRaw  = card.dataset.areas     || '';
      var areas     = areasRaw ? areasRaw.split(',') : [];

      var cityMatch    = !q || normalize(cityName).includes(q);
      var areaMatch    = q && areas.some(function (a) { return normalize(a).includes(q); });
      var stationMatch = !!(stationHits[citySlug]);

      if (!q || cityMatch || areaMatch || stationMatch) {
        card.style.display = '';
        visibleCount++;

        /* エリアタグをハイライト */
        card.querySelectorAll('.area-tag').forEach(function (tag) {
          var aName    = tag.dataset.areaName || '';
          var aSlug    = tag.dataset.areaSlug || '';
          var hlByArea = q && normalize(aName).includes(q);
          var hlByStation = stationMatch && stationHits[citySlug].some(function (h) {
            return h.areaSlug === aSlug;
          });
          if (hlByArea || hlByStation) {
            tag.style.color           = 'var(--color-gold)';
            tag.style.borderColor     = 'var(--color-gold)';
            tag.style.backgroundColor = 'rgba(184,150,12,0.07)';
          } else {
            tag.style.color           = '';
            tag.style.borderColor     = '';
            tag.style.backgroundColor = '';
          }
        });

        /* ヒント文字列を収集（駅名マッチ優先） */
        if (stationMatch) {
          stationHits[citySlug].forEach(function (h) {
            if (hintParts.length < 4) {
              hintParts.push(h.station + ' → ' + h.areaName + '（' + h.cityName + '）');
            }
          });
        } else if (q) {
          areas.forEach(function (a) {
            if (normalize(a).includes(q) && hintParts.length < 4) {
              hintParts.push(a + '（' + cityName + '）');
            }
          });
        }
      } else {
        card.style.display = 'none';
        card.querySelectorAll('.area-tag').forEach(function (tag) {
          tag.style.color = tag.style.borderColor = tag.style.backgroundColor = '';
        });
      }
    });

    searchHint.textContent = (q && hintParts.length) ? hintParts.join('、') : '';
    noResults.classList.toggle('hidden', visibleCount > 0);
    searchClear.classList.toggle('hidden', !q);
  }

  searchInput.addEventListener('input', function () { filterCards(searchInput.value); });
  searchClear.addEventListener('click', function () {
    searchInput.value = '';
    filterCards('');
    searchInput.focus();
  });
})();
</script>

---
pagination:
  data: areas
  size: 1
  alias: prefecture
permalink: "/stories/area/{{ prefecture.slug }}/"
layout: area.njk
---
{# L1: 都道府県インデックス #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Third Place Japan", "item": "{{ site.url }}" },
    { "@type": "ListItem", "position": 2, "name": "Stories", "item": "{{ site.url }}/stories/" },
    { "@type": "ListItem", "position": 3, "name": "場所をめぐる", "item": "{{ site.url }}/stories/area/" },
    { "@type": "ListItem", "position": 4, "name": "{{ prefecture.name }}", "item": "{{ site.url }}/stories/area/{{ prefecture.slug }}/" }
  ]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "{{ prefecture.name }}でTPJ認証を受けたサードプレイスはどこですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ prefecture.name }}のThird Place Japan認証店舗は{{ site.url }}/stories/area/{{ prefecture.slug }}/からエリア・業種別に探せます。カフェ・ホテルラウンジ・スパ・コワーキングなど多業種の認証施設を掲載しています。"
      }
    },
    {
      "@type": "Question",
      "name": "{{ prefecture.name }}の市区町村ごとにTPJ認証店舗を探せますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "はい。{{ prefecture.name }}の認証店舗は市区町村ごとに絞り込んで探せます。さらにエリア（例：渋谷・青山）と業種（例：カフェ）の掛け合わせでも検索できます。"
      }
    }
  ]
}
</script>

<div class="max-w-6xl mx-auto px-6 py-24">

  <nav class="flex items-center gap-2 text-xs text-muted mb-12">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span>/</span>
    <a href="/stories/area/" class="hover:text-gold transition-colors">場所をめぐる</a>
    <span>/</span>
    <span>{{ prefecture.name }}</span>
  </nav>

  <div class="mb-16" data-aos="fade-up">
    <p class="label mb-4">{{ prefecture.name }}</p>
    <h1 class="font-serif text-4xl font-light text-dark mb-4">
      {{ prefecture.name }}のサードプレイス
    </h1>
    <div class="gold-rule"></div>
  </div>

  {# 検索ボックス #}
  <section class="mb-12" data-aos="fade-up">
    <div class="flex items-center border border-border bg-white focus-within:border-gold transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0 ml-4" style="color:var(--color-muted)" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input type="text" id="area-search"
        placeholder="エリア・駅名で検索（例：表参道、青山、渋谷）"
        class="w-full px-4 py-4 text-sm focus:outline-none bg-transparent" />
      <button id="search-clear" class="hidden px-4 transition-colors" style="color:var(--color-muted)" aria-label="クリア">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M18 6 6 18M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <p id="search-hint" class="mt-2 text-xs min-h-[1.25em]" style="color:var(--color-muted)"></p>
  </section>

  {# 市区町村リスト #}
  <section class="mb-16" data-aos="fade-up">
    <p class="label mb-6">エリアから探す</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="city-grid">
      {% for city in prefecture.cities %}
      <div class="city-card border border-border p-4 transition-colors"
           data-city-name="{{ city.name }}"
           data-areas="{% for area in city.areas %}{{ area.name }}{% if not loop.last %},{% endif %}{% endfor %}"
           data-area-slugs="{% for area in city.areas %}{{ area.slug }}{% if not loop.last %},{% endif %}{% endfor %}"
           data-city-slug="{{ city.slug }}">
        <a href="/stories/area/{{ prefecture.slug }}/{{ city.slug }}/"
           class="block hover:text-gold transition-colors city-link">
          <p class="font-serif text-base font-light">{{ city.name }}</p>
          {% set cityVenues = venues | venuesByArea(prefecture.slug, city.slug) %}
          {% if cityVenues.length %}
          <p class="text-xs mt-0.5" style="color:var(--color-muted)">{{ cityVenues.length }}件の認証店舗</p>
          {% endif %}
        </a>
        {% if city.areas.length %}
        <div class="flex flex-wrap gap-1 mt-3">
          {% for area in city.areas %}
          <a href="/stories/area/{{ prefecture.slug }}/{{ city.slug }}/{{ area.slug }}/"
             class="area-tag inline-block text-xs border border-border rounded-full px-2 py-0.5 hover:border-gold hover:text-gold transition-colors"
             style="color:var(--color-muted)"
             data-area-name="{{ area.name }}">{{ area.name }}</a>
          {% endfor %}
        </div>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    <div id="no-results" class="hidden py-8 text-center text-sm" style="color:var(--color-muted)">
      一致するエリア・駅名が見つかりませんでした
    </div>
  </section>

  {# この都道府県の全認証店舗 #}
  {% set prefVenues = venues | venuesByArea(prefecture.slug) %}
  {% if prefVenues.length %}
  <section data-aos="fade-up">
    <p class="label mb-6">認証店舗</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for v in prefVenues | sortByGrade %}
      {% set cardVenue = v %}{% include "venue-card.njk" %}
      {% endfor %}
    </div>
  </section>
  {% endif %}

</div>

<script>
(function () {
  var searchInput = document.getElementById('area-search');
  var searchClear = document.getElementById('search-clear');
  var searchHint  = document.getElementById('search-hint');
  var cityCards   = document.querySelectorAll('.city-card');
  var noResults   = document.getElementById('no-results');
  var prefSlug    = '{{ prefecture.slug }}';

  function normalize(str) {
    return (str || '').toLowerCase().replace(/[\s　]/g, '');
  }

  function filterCards(query) {
    var q = normalize(query);
    var visibleCount = 0;
    var hintParts = [];

    cityCards.forEach(function (card) {
      var cityName   = card.dataset.cityName  || '';
      var citySlug   = card.dataset.citySlug  || '';
      var areasRaw   = card.dataset.areas     || '';
      var slugsRaw   = card.dataset.areaSlugs || '';
      var areas      = areasRaw ? areasRaw.split(',') : [];
      var areaSlugs  = slugsRaw ? slugsRaw.split(',') : [];

      var cityMatch    = !q || normalize(cityName).includes(q);
      var matchingIdx  = [];
      areas.forEach(function (a, i) {
        if (q && normalize(a).includes(q)) matchingIdx.push(i);
      });
      var areaMatch = matchingIdx.length > 0;

      if (!q || cityMatch || areaMatch) {
        card.style.display = '';
        visibleCount++;

        // highlight matching area tags
        card.querySelectorAll('.area-tag').forEach(function (tag) {
          var aName = tag.dataset.areaName || '';
          if (q && normalize(aName).includes(q)) {
            tag.classList.add('border-gold-hl');
            tag.style.color = 'var(--color-gold)';
            tag.style.borderColor = 'var(--color-gold)';
            tag.style.backgroundColor = 'rgba(184,150,12,0.07)';
            // collect for hint
            if (hintParts.length < 4) hintParts.push(aName + '（' + cityName + '）');
          } else {
            tag.style.color = '';
            tag.style.borderColor = '';
            tag.style.backgroundColor = '';
          }
        });
      } else {
        card.style.display = 'none';
      }
    });

    // search hint
    if (q && hintParts.length) {
      searchHint.textContent = hintParts.join('、');
    } else {
      searchHint.textContent = '';
    }

    noResults.classList.toggle('hidden', visibleCount > 0);
    searchClear.classList.toggle('hidden', !q);
  }

  searchInput.addEventListener('input', function () {
    filterCards(searchInput.value);
  });

  searchClear.addEventListener('click', function () {
    searchInput.value = '';
    filterCards('');
    searchInput.focus();
  });
})();
</script>

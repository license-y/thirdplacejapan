---
pagination:
  data: areaL2
  size: 1
  alias: item
permalink: "/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/"
layout: area.njk
---
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Stories", "item": "{{ site.url }}/stories/" },
    { "@type": "ListItem", "position": 2, "name": "{{ item.prefecture.name }}", "item": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/" },
    { "@type": "ListItem", "position": 3, "name": "{{ item.city.name }}", "item": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/" }
  ]
}
</script>

<div class="max-w-6xl mx-auto px-6 py-24">

  <nav class="flex items-center gap-2 text-xs text-muted mb-12">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span>/</span>
    <a href="/stories/area/{{ item.prefecture.slug }}/" class="hover:text-gold transition-colors">{{ item.prefecture.name }}</a>
    <span>/</span>
    <span>{{ item.city.name }}</span>
  </nav>

  <div class="mb-16" data-aos="fade-up">
    <p class="label mb-4">{{ item.prefecture.name }}</p>
    <h1 class="font-serif text-4xl font-light text-dark mb-4">
      {{ item.city.name }}のサードプレイス
    </h1>
    <div class="gold-rule"></div>
  </div>

  {# エリア（L3）リスト #}
  {% if item.city.areas and item.city.areas.length %}
  <section class="mb-16" data-aos="fade-up">
    <p class="label mb-6">エリアから探す</p>
    <div class="flex flex-wrap gap-3">
      {% for area in item.city.areas %}
      <a href="/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ area.slug }}/"
         class="text-xs border border-border px-4 py-2 hover:border-gold hover:text-gold transition-colors">
        {{ area.name }}
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# この市区町村の認証店舗 #}
  {% set cityVenues = venues | venuesByArea(item.prefecture.slug, item.city.slug) %}
  {% if cityVenues.length %}
  <section data-aos="fade-up">
    <p class="label mb-6">認証店舗</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for v in cityVenues | sortByGrade %}
      {% set cardVenue = v %}{% include "venue-card.njk" %}
      {% endfor %}
    </div>
  </section>
  {% else %}
  <p class="text-sm text-muted" data-aos="fade-up">この地域の認証店舗は準備中です。</p>
  {% endif %}

</div>

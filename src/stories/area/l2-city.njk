---
pagination:
  data: areaL2
  size: 1
  alias: item
permalink: "/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/"
layout: area.njk
---
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Third Place Japan", "item": "{{ site.url }}" },
    { "@type": "ListItem", "position": 2, "name": "Stories", "item": "{{ site.url }}/stories/" },
    { "@type": "ListItem", "position": 3, "name": "{{ item.prefecture.name }}", "item": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/" },
    { "@type": "ListItem", "position": 4, "name": "{{ item.city.name }}", "item": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/" }
  ]
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "{{ item.city.name }}でサードプレイスとして認証された場所はどこですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.city.name }}のThird Place Japanセレクト店舗は{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/から確認できます。7軸評価（居心地・静寂性・特別感など）で認証された施設を掲載しています。"
      }
    },
    {
      "@type": "Question",
      "name": "{{ item.city.name }}で一人でゆっくり過ごせるカフェやスペースは？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.city.name }}のTPJセレクト店舗のうち、静寂性・プライバシースコアが高い施設がおすすめです。Third Place Japan Storiesのエリアページから業種別に絞り込んで探せます。"
      }
    }
  ]
}
</script>

{# CollectionPage JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "{{ item.city.name }}のサードプレイス | Third Place Japan",
  "description": "{{ item.city.name }}（{{ item.prefecture.name }}）でThird Place Japanが認証したサードプレイス。エリア別・カテゴリ別に7軸評価基準で認証した場所を掲載。",
  "url": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/",
  "inLanguage": "ja",
  "about": { "@type": "AdministrativeArea", "name": "{{ item.city.name }}", "containedInPlace": { "@type": "AdministrativeArea", "name": "{{ item.prefecture.name }}" } },
  "publisher": { "@type": "Organization", "name": "Third Place Japan", "url": "{{ site.url }}" },
  "hasPart": [
    {% for area in item.city.areas %}
    { "@type": "WebPage", "name": "{{ area.name }}のサードプレイス", "url": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ area.slug }}/" }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

{# AdministrativeArea JSON-LD（全市区町村に適用）#}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "AdministrativeArea",
  "name": "{{ item.city.name }}",
  "description": "{{ item.city.name }}（{{ item.prefecture.name }}）のサードプレイス認証エリア。Third Place Japanが7軸基準で認証したカフェ・ホテル・スパ・コワーキングなどを掲載。",
  "url": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/",
  "containedInPlace": { "@type": "AdministrativeArea", "name": "{{ item.prefecture.name }}" },
  "hasMap": "https://www.google.com/maps/search/{{ item.city.name }}+{{ item.prefecture.name }}"
}
</script>

{% if item.prefecture.slug == 'tokyo' %}
{# ── 東京都の全市区町村：2カラム＋Googleマップ ── #}

<div class="max-w-6xl mx-auto px-6 py-24">
  <nav class="flex items-center gap-2 text-xs text-muted mb-12">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span>/</span>
    <a href="/stories/area/{{ item.prefecture.slug }}/" class="hover:text-gold transition-colors">{{ item.prefecture.name }}</a>
    <span>/</span>
    <span>{{ item.city.name }}</span>
  </nav>
  <div class="mb-12" data-aos="fade-up">
    <p class="label mb-4">{{ item.prefecture.name }}</p>
    <h1 class="font-serif text-4xl font-light text-dark mb-4">{{ item.city.name }}のサードプレイス</h1>
    <div class="gold-rule"></div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 items-start">
    {# メインコンテンツ #}
    <div class="lg:col-span-2">
      {% if item.city.areas and item.city.areas.length %}
      <section class="mb-12" data-aos="fade-up">
        <p class="label mb-6">エリアから探す</p>
        <div class="flex flex-wrap gap-3">
          {% for area in item.city.areas %}
          <a href="/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ area.slug }}/"
             class="text-xs border border-border px-4 py-2 hover:border-gold hover:text-gold transition-colors rounded-full">
            {{ area.name }}
          </a>
          {% endfor %}
        </div>
      </section>
      {% endif %}
      {# 業種から探す #}
      <section class="mb-12" data-aos="fade-up">
        <p class="label mb-6">業種から探す</p>
        <div class="flex flex-wrap gap-3">
          {% for cat in areaL2Cat %}
          {% if cat.prefecture.slug == item.prefecture.slug and cat.city.slug == item.city.slug %}
          <a href="/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ cat.category.slug }}/"
             class="text-xs border border-border px-4 py-2 hover:border-gold hover:text-gold transition-colors rounded-full">
            {{ cat.category.name_ja }}
          </a>
          {% endif %}
          {% endfor %}
        </div>
      </section>
      {% set cityArticles = collections.articles | rejectLang("en") | articlesByCity(item.prefecture.slug, item.city.slug) %}
      {% if cityArticles.length %}
      <section class="mb-12" data-aos="fade-up">
        <p class="label mb-6">{{ item.city.name }}の関連記事</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {% for post in cityArticles %}
          <a href="{{ post.url }}" class="group block rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow bg-white">
            {% if post.data.thumbnail %}
            <div class="aspect-video overflow-hidden">
              <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" decoding="async">
            </div>
            {% endif %}
            <div class="p-4">
              <p class="text-xs text-muted mb-2">{{ post.date | dateJa }}</p>
              <p class="text-sm font-medium text-dark leading-snug group-hover:text-gold transition-colors">{{ post.data.title }}</p>
            </div>
          </a>
          {% endfor %}
        </div>
      </section>
      {% endif %}
      {% set cityVenues = venues | venuesByArea(item.prefecture.slug, item.city.slug) %}
      {% if cityVenues.length %}
      <section data-aos="fade-up">
        <p class="label mb-6">セレクト店舗</p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {% for v in cityVenues | sortByGrade %}
          {% set cardVenue = v %}{% include "venue-card.njk" %}
          {% endfor %}
        </div>
      </section>
      {% else %}
      <p class="text-sm text-muted" data-aos="fade-up">この地域のセレクト店舗は準備中です。</p>
      {% endif %}
    </div>

    {# サイドバー #}
    <aside class="lg:col-span-1 space-y-8 lg:sticky lg:top-24" data-aos="fade-up">
      <div>
        <p class="label mb-3">{{ item.city.name }}のマップ</p>
        <div class="overflow-hidden border border-border">
          <iframe
            title="{{ item.city.name }}のGoogleマップ"
            src="https://maps.google.com/maps?q={{ item.city.name }}+{{ item.prefecture.name }}&output=embed&hl=ja&z=13"
            width="100%" height="260" style="border:0;display:block"
            loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
        <a href="https://www.google.com/maps/search/{{ item.city.name }}+{{ item.prefecture.name }}"
           target="_blank" rel="noopener noreferrer"
           class="flex items-center gap-1 mt-2 text-xs hover:text-gold transition-colors" style="color:var(--color-muted)">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Googleマップで{{ item.city.name }}を開く
        </a>
      </div>
      <div>
        <p class="label mb-3">{{ item.prefecture.name }}のマップ</p>
        <div class="overflow-hidden border border-border">
          <iframe
            title="{{ item.prefecture.name }}のGoogleマップ"
            src="https://maps.google.com/maps?q={{ item.prefecture.name }}&output=embed&hl=ja&z=10"
            width="100%" height="220" style="border:0;display:block"
            loading="lazy" allowfullscreen referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
        <a href="/stories/area/{{ item.prefecture.slug }}/"
           class="flex items-center gap-1 mt-2 text-xs hover:text-gold transition-colors" style="color:var(--color-muted)">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
          {{ item.prefecture.name }}の全エリアへ
        </a>
      </div>
      <div class="border-t border-border pt-6">
        <p class="text-xs leading-relaxed" style="color:var(--color-muted)">
          Third Place Japanは{{ item.city.name }}のセレクト施設情報を独自の7軸基準で評価・掲載しています。
        </p>
      </div>
    </aside>
  </div>
</div>

{% else %}
{# ── 通常レイアウト ── #}
<div class="max-w-6xl mx-auto px-6 py-24">
  <nav class="flex items-center gap-2 text-xs text-muted mb-12">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span>/</span>
    <a href="/stories/area/{{ item.prefecture.slug }}/" class="hover:text-gold transition-colors">{{ item.prefecture.name }}</a>
    <span>/</span>
    <span>{{ item.city.name }}</span>
  </nav>
  <div class="mb-16" data-aos="fade-up">
    <p class="label mb-4">{{ item.prefecture.name }}</p>
    <h1 class="font-serif text-4xl font-light text-dark mb-4">{{ item.city.name }}のサードプレイス</h1>
    <div class="gold-rule"></div>
  </div>
  {% if item.city.areas and item.city.areas.length %}
  <section class="mb-16" data-aos="fade-up">
    <p class="label mb-6">エリアから探す</p>
    <div class="flex flex-wrap gap-3">
      {% for area in item.city.areas %}
      <a href="/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ area.slug }}/"
         class="text-xs border border-border px-4 py-2 hover:border-gold hover:text-gold transition-colors rounded-full">
        {{ area.name }}
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}
  {# 業種から探す #}
  <section class="mb-16" data-aos="fade-up">
    <p class="label mb-6">業種から探す</p>
    <div class="flex flex-wrap gap-3">
      {% for cat in areaL2Cat %}
      {% if cat.prefecture.slug == item.prefecture.slug and cat.city.slug == item.city.slug %}
      <a href="/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ cat.category.slug }}/"
         class="text-xs border border-border px-4 py-2 hover:border-gold hover:text-gold transition-colors rounded-full">
        {{ cat.category.name_ja }}
      </a>
      {% endif %}
      {% endfor %}
    </div>
  </section>
  {% set cityArticles = collections.articles | rejectLang("en") | articlesByCity(item.prefecture.slug, item.city.slug) %}
  {% if cityArticles.length %}
  <section class="mb-16" data-aos="fade-up">
    <p class="label mb-6">{{ item.city.name }}の関連記事</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for post in cityArticles %}
      <a href="{{ post.url }}" class="group block rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow bg-white">
        {% if post.data.thumbnail %}
        <div class="aspect-video overflow-hidden">
          <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" decoding="async">
        </div>
        {% endif %}
        <div class="p-4">
          <p class="text-xs text-muted mb-2">{{ post.date | dateJa }}</p>
          <p class="text-sm font-medium text-dark leading-snug group-hover:text-gold transition-colors">{{ post.data.title }}</p>
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}
  {% set cityVenues = venues | venuesByArea(item.prefecture.slug, item.city.slug) %}
  {% if cityVenues.length %}
  <section data-aos="fade-up">
    <p class="label mb-6">セレクト店舗</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for v in cityVenues | sortByGrade %}
      {% set cardVenue = v %}{% include "venue-card.njk" %}
      {% endfor %}
    </div>
  </section>
  {% else %}
  <p class="text-sm text-muted" data-aos="fade-up">この地域のセレクト店舗は準備中です。</p>
  {% endif %}
</div>
{% endif %}

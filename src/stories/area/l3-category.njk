---
pagination:
  data: areaL3Cat
  size: 1
  alias: item
permalink: "/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ item.area.slug }}/{{ item.category.slug }}/"
layout: area.njk
---
{# ──── FAQPage JSON-LD（5クエリ対応）──── #}
{%- set allVenueText = item.venues | sortByGrade | venuesToAnswerText -%}
{%- set silentVenues = item.venues | venuesByMinScore("silence", 8) -%}
{%- set specialVenues = item.venues | venuesByMinScore("special", 8) -%}
{%- set revisitVenues = item.venues | venuesByMinScore("revisit", 8) -%}
{%- set inboundVenues = item.venues | venuesByMinScore("inbound", 7) -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "{{ item.area.name }}でサードプレイスとして認証された{{ item.category.name_ja }}はどこですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Third Place Japanが{{ item.area.name }}エリアで認証した{{ item.category.name_ja }}は{{ allVenueText }}です。いずれも独自の7軸評価基準（居心地・静寂性・特別感・ストーリー・再訪価値・記録体験・インバウンド対応）に基づき認証されています。"
      }
    },
    {
      "@type": "Question",
      "name": "{{ item.area.name }}で静かに過ごせる{{ item.category.name_ja }}は？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.area.name }}で静寂性に優れると Third Place Japan が評価した{{ item.category.name_ja }}として、{{ silentVenues | venuesToScoreText("silence", "静寂性スコア") }}があります。"
      }
    },
    {
      "@type": "Question",
      "name": "{{ item.area.name }}で特別な体験ができる{{ item.category.name_ja }}は？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.area.name }}で特別感・非日常性に優れると評価された{{ item.category.name_ja }}として、{{ specialVenues | venuesToScoreText("special", "特別感スコア") }}があります。"
      }
    },
    {
      "@type": "Question",
      "name": "{{ item.area.name }}で何度でも通いたくなる{{ item.category.name_ja }}は？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.area.name }}で再訪・継続価値に優れると評価された{{ item.category.name_ja }}として、{{ revisitVenues | venuesToScoreText("revisit", "再訪価値スコア") }}があります。"
      }
    },
    {
      "@type": "Question",
      "name": "{{ item.area.name }}の{{ item.category.name_ja }}でインバウンド対応のある場所は？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Third Place Japanが{{ item.area.name }}でインバウンド対応に優れると評価した{{ item.category.name_ja }}として、{{ inboundVenues | venuesToScoreText("inbound", "インバウンドスコア") }}があります。"
      }
    }
  ]
}
</script>

{# ──── ItemList JSON-LD ──── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "{{ item.area.name }}の{{ item.category.name_ja }} — Third Place Japan 認証一覧",
  "description": "Third Place Japanが{{ item.area.name }}エリアで7軸評価基準により認証した{{ item.category.name_ja }}",
  "url": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ item.area.slug }}/{{ item.category.slug }}/",
  "numberOfItems": {{ item.venues | length }},
  "itemListElement": [
    {% for v in item.venues | sortByGrade %}
    {
      "@type": "ListItem",
      "position": {{ loop.index }},
      "name": "{{ v.name }}",
      "url": "{{ site.url }}/stories/certified/{{ v.slug }}/",
      "description": "{{ v.citation | replace('"', '\\"') | truncate(120) }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

{# ──── BreadcrumbList JSON-LD ──── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Stories", "item": "{{ site.url }}/stories/" },
    { "@type": "ListItem", "position": 2, "name": "{{ item.prefecture.name }}", "item": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/" },
    { "@type": "ListItem", "position": 3, "name": "{{ item.city.name }}", "item": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/" },
    { "@type": "ListItem", "position": 4, "name": "{{ item.area.name }}", "item": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ item.area.slug }}/" },
    { "@type": "ListItem", "position": 5, "name": "{{ item.category.name_ja }}", "item": "{{ site.url }}/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ item.area.slug }}/{{ item.category.slug }}/" }
  ]
}
</script>

<div class="max-w-6xl mx-auto px-6 py-24">

  {# パンくず #}
  <nav class="flex items-center flex-wrap gap-2 text-xs text-muted mb-12">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span>/</span>
    <a href="/stories/area/{{ item.prefecture.slug }}/" class="hover:text-gold transition-colors">{{ item.prefecture.name }}</a>
    <span>/</span>
    <a href="/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/" class="hover:text-gold transition-colors">{{ item.city.name }}</a>
    <span>/</span>
    <a href="/stories/area/{{ item.prefecture.slug }}/{{ item.city.slug }}/{{ item.area.slug }}/" class="hover:text-gold transition-colors">{{ item.area.name }}</a>
    <span>/</span>
    <span>{{ item.category.name_ja }}</span>
  </nav>

  {# ──── ハブヘッダー ──── #}
  <div class="mb-14" data-aos="fade-up">
    <p class="label mb-4">{{ item.area.name }} × {{ item.category.name_ja }}</p>
    <h1 class="font-serif text-4xl md:text-5xl font-light text-dark mb-4 leading-tight">
      {{ item.area.name }}の<br>{{ item.category.name_ja }}
    </h1>
    <div class="gold-rule mb-8"></div>
    <p class="text-base text-text leading-relaxed max-w-xl">
      Third Place Japanが独自の7軸評価基準で認証した、<br class="hidden md:block">
      {{ item.area.name }}エリアの{{ item.category.name_ja }}。<br class="hidden md:block">
      それぞれの場所が持つ固有の価値を、静かに記録しています。
    </p>
  </div>

  {# ──── この面が答える問い ──── #}
  <section class="mb-14 p-6 bg-white border border-border" data-aos="fade-up">
    <p class="label mb-4">この面が答える問い</p>
    <ul class="space-y-2 text-sm text-text">
      <li class="flex items-start gap-2">
        <span class="text-gold mt-0.5 shrink-0">—</span>
        <span>{{ item.area.name }}でサードプレイスとして認証された{{ item.category.name_ja }}はどこか</span>
      </li>
      {% if silentVenues.length %}
      <li class="flex items-start gap-2">
        <span class="text-gold mt-0.5 shrink-0">—</span>
        <span>{{ item.area.name }}で静かに過ごせる・仕事に集中できる場所はどこか</span>
      </li>
      {% endif %}
      {% if specialVenues.length %}
      <li class="flex items-start gap-2">
        <span class="text-gold mt-0.5 shrink-0">—</span>
        <span>{{ item.area.name }}で特別な体験・非日常を味わえる場所はどこか</span>
      </li>
      {% endif %}
      {% if revisitVenues.length %}
      <li class="flex items-start gap-2">
        <span class="text-gold mt-0.5 shrink-0">—</span>
        <span>{{ item.area.name }}で何度でも通いたくなる場所はどこか</span>
      </li>
      {% endif %}
    </ul>
  </section>

  {# ──── 関連記事 ──── #}
  {% set areaArticles = collections.articles | articlesByArea(item.area.slug) | articlesByCategory(item.category.slug) %}
  {% if areaArticles and areaArticles.length %}
  <section class="mb-14" data-aos="fade-up">
    <p class="label mb-6">関連記事 — {{ areaArticles.length }}件</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {% for post in areaArticles %}
      <a href="{{ post.url }}" class="group rounded-xl overflow-hidden bg-white shadow-sm hover:shadow-md transition-all border border-gold/30 hover:border-gold">
        {% if post.data.thumbnail %}
        <div class="aspect-video overflow-hidden">
          <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
               loading="lazy" decoding="async">
        </div>
        {% endif %}
        <div class="p-4">
          <h3 class="font-serif text-sm font-light text-dark group-hover:text-gold transition-colors leading-snug mb-2" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{{ post.data.title }}</h3>
          <p class="text-[10px] text-muted">{{ post.date | dateJa }}</p>
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ──── 認証店舗一覧（グレード降順）──── #}
  {% if item.venues and item.venues.length %}
  <section class="mb-14" data-aos="fade-up">
    <p class="label mb-6">認証店舗 — {{ item.venues | length }}件</p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for v in item.venues | sortByGrade %}
      {% set cardVenue = v %}{% include "venue-card.njk" %}
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ──── 評価軸別インデックス ──── #}
  {% set axisGroups = item.venues | groupByProp("axes_primary") %}
  {% if axisGroups.length > 1 %}
  <section class="mb-14" data-aos="fade-up">
    <p class="label mb-6">評価軸から探す</p>
    <div class="space-y-5">
      {% for group in axisGroups %}
      <div class="border-l-2 border-border pl-6 hover:border-gold transition-colors">
        <p class="text-xs text-gold mb-3">{{ group.key }}</p>
        <div class="flex flex-wrap gap-3">
          {% for v in group.items %}
          <a href="/stories/certified/{{ v.slug }}/"
             class="flex items-center gap-2 text-sm text-text hover:text-gold transition-colors">
            <span class="grade-badge text-xs py-0.5 px-2">{{ v.grade }}</span>
            <span>{{ v.name }}</span>
          </a>
          {% endfor %}
        </div>
      </div>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# ──── 余白（場所としての静けさ）──── #}
  <div class="mt-6 pt-10 border-t border-border text-center" data-aos="fade-up">
    <p class="font-serif text-sm text-muted italic leading-relaxed">
      「この場所は、まだ見つかっていません。」
    </p>
    <p class="text-xs text-muted mt-3">
      <a href="/" class="hover:text-gold transition-colors">Third Place Japanについて</a>
    </p>
  </div>

</div>

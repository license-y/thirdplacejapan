    { "@type": "ListItem", "position": 3, "name": "サードプレイスとは", "item": "{{ site.url }}/stories/about/" }
  ]
}
</script>

{# DefinedTermSet JSON-LD（強化版）#}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "name": "Third Place Japan サードプレイス用語集",
  "url": "{{ site.url }}/stories/about/",
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", "h2"]
  },
  "hasDefinedTerm": [
    {
      "@type": "DefinedTerm",
      "name": "サードプレイス",
      "alternateName": ["第三の居場所", "Third Place"],
      "description": "家（ファーストプレイス）と職場・学校（セカンドプレイス）に次ぐ、第三の居場所のこと。社会学者レイ・オルデンバーグが提唱した概念で、誰もが気軽に参加でき、自分らしくいられる空間を指す。",
      "url": "{{ site.url }}/stories/about/what-is-third-place/"
    },
    {
      "@type": "DefinedTerm",
      "name": "TPJ7軸評価",
      "alternateName": ["7軸評価基準", "7-Axis Evaluation"],
      "description": "Third Place Japanが独自に定めた7つの評価軸：①居心地・空間品質、②静寂性・プライバシー、③特別感・非日常性、④ストーリー・背景への共感、⑤再訪・継続価値、⑥記録・シェア体験、⑦インバウンド・多言語対応。各軸10点満点で採点する。",
      "url": "{{ site.url }}/stories/about/"
    },
    {
      "@type": "DefinedTerm",
      "name": "TPJ認証グレード",
      "alternateName": ["認証グレード", "Certification Grade"],
      "description": "TPJの認証はCertified・Standard・Silver・Gold・Flagshipの5段階。Flagshipが最高グレードで、7軸すべてにおいて卓越した空間体験を提供する施設に与えられる。",
      "url": "{{ site.url }}/stories/certified/"
    }
  ]
}
</script>

<div class="max-w-3xl mx-auto px-6 py-20">

  <nav class="flex items-center gap-2 text-xs text-muted mb-12">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span>／</span>
    <span>サードプレイスとは</span>
  </nav>

  <div class="mb-16" data-aos="fade-up">
    <p class="label mb-4">サードプレイスとは</p>
    <h1 class="font-serif text-4xl font-light text-dark mb-4">「第三の居場所」とは何か</h1>
    <div class="gold-rule mb-6"></div>
    <p class="text-sm text-muted max-w-2xl leading-relaxed">
      家（ファーストプレイス）と職場（セカンドプレイス）に次ぐ、第三の居場所——。<br class="hidden md:block">
      社会学者レイ・オルデンバーグが提唱したこの概念を、TPJが日本の文脈で再定義します。
    </p>
  </div>

  {# 記事一覧 #}
  {% set aboutPosts = collections.aboutArticles %}
  {% if aboutPosts and aboutPosts.length %}
  <div class="space-y-4" data-aos="fade-up">
    {% for post in aboutPosts %}
    <a href="{{ post.url }}"
       class="group flex items-stretch bg-white rounded-2xl overflow-hidden border border-border hover:border-gold shadow-sm hover:shadow-md transition-all">
      {% if post.data.thumbnail %}
      <div class="shrink-0 w-40 md:w-52 overflow-hidden">
        <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}"
             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
             loading="lazy" decoding="async">
      </div>
      {% else %}
      <div class="shrink-0 w-40 md:w-52 bg-ivory flex items-center justify-center">
        <span class="text-muted text-xs tracking-wider">TPJ Stories</span>
      </div>
      {% endif %}
      <div class="p-5 md:p-6 flex flex-col justify-center min-w-0">
        <span class="inline-block text-xs text-gold border border-gold rounded-full px-3 py-0.5 mb-3 w-fit">サードプレイスとは</span>
        <h2 class="font-serif text-base md:text-lg font-light text-dark group-hover:text-gold transition-colors leading-snug mb-2"
            style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
          {{ post.data.title }}
        </h2>
        {% if post.data.description %}
        <p class="text-sm text-muted leading-relaxed"
           style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
          {{ post.data.description }}
        </p>
        {% endif %}
      </div>
    </a>
    {% endfor %}
  </div>
  {% else %}
  <div class="text-center py-16" data-aos="fade-up">
    <p class="font-serif text-xl font-light text-dark mb-4">準備中です</p>
    <p class="text-sm text-muted">サードプレイスの基礎知識記事を順次公開予定です。</p>
    <p class="text-xs text-muted mt-6">
      <a href="/stories/" class="hover:text-gold transition-colors">← Storiesトップへ</a>
    </p>
  </div>
  {% endif %}

</div>

---
title: "Third Place Japan Stories | 場所について、読む。"
description: "サードプレイスの文化・場所・体験を伝える読み物ポータルメディア。15カテゴリ・エリア別に、日本のサードプレイスを探す。"
canonical: "/stories/"
---

{# WebSite JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Third Place Japan Stories",
  "url": "{{ site.url }}/stories/",
  "description": "サードプレイスの文化・場所・体験を伝える読み物ポータルメディア",
  "inLanguage": "ja",
  "publisher": {
    "@type": "Organization",
    "name": "Third Place Japan",
    "url": "{{ site.url }}"
  }
}
</script>

{# FAQPage JSON-LD（AEO対策）#}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Third Place Japan Storiesとは何ですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Third Place Japan Stories（サードプレイスジャパン編集部）は、日本全国のサードプレイス（第三の居場所）を15カテゴリで紹介する読み物ポータルメディアです。カフェ・神社・ホテル・貸切ヴィラ・自然体験など、業種横断で「居場所」を伝えます。"
      }
    },
    {
      "@type": "Question",
      "name": "サードプレイスとはどういう意味ですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "サードプレイスとは、家（ファーストプレイス）と職場（セカンドプレイス）に次ぐ第三の居場所のことです。社会学者レイ・オルデンバーグが提唱した概念で、役割から解放されてただ「いる」ことができる場所を指します。"
      }
    },
    {
      "@type": "Question",
      "name": "東京でおすすめのサードプレイスはどこですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "東京でのサードプレイスとしては、渋谷・表参道エリアのスペシャルティカフェ、明治神宮などの神社、静かなホテルラウンジ、北参道・代官山のコワーキングスペースなどが挙げられます。TPJはこれらを7軸評価基準で評価・認証しています。"
      }
    }
  ]
}
</script>

<section class="max-w-6xl mx-auto px-6 py-24">

  {# Hero #}
  <div class="mb-20" data-aos="fade-up">
    <p class="label mb-4">Third Place Japan Stories</p>
    <h1 class="font-serif text-4xl md:text-5xl font-light text-dark leading-tight mb-6">
      場所について、<br>読む。
    </h1>
    <div class="gold-rule mb-6"></div>
    <p class="text-sm text-muted max-w-xl text-left md:text-center md:mx-auto">
      家でも職場でもない「第三の居場所」——<br class="hidden md:block">
      サードプレイスを知り、探し、体験するための読み物。
    </p>
  </div>

  {# ピラー記事（TPJガイド）#}
  {% if collections.aboutArticles and collections.aboutArticles.length %}
  <div class="mb-20" data-aos="fade-up">
    <div class="border border-border rounded-[2rem] p-6 md:p-10" style="background:rgba(255,255,255,0.6);">

      {# セクションヘッダー #}
      <div class="flex items-center gap-3 mb-7">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted shrink-0" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
        <h2 class="font-serif text-xl font-light text-dark">TPJガイド</h2>
        <span class="text-sm text-muted hidden md:inline">— サードプレイスを深く知るための入口</span>
      </div>

      {# 記事グリッド #}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="pillar-grid">
        {% for post in collections.aboutArticles %}
        <a href="{{ post.url }}"
           class="group flex items-stretch bg-white rounded-2xl border border-border hover:border-gold shadow-sm hover:shadow-md transition-all overflow-hidden{% if loop.index > 6 %} pillar-extra hidden{% elif loop.index > 4 %} pillar-extra hidden md:flex{% endif %}">
          {% if post.data.thumbnail %}
          <div class="shrink-0 w-24 overflow-hidden">
            <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}"
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                 loading="lazy" decoding="async">
          </div>
          {% else %}
          <div class="shrink-0 w-24 bg-ivory flex items-center justify-center">
            <span class="text-muted text-xs">TPJ</span>
          </div>
          {% endif %}
          <div class="p-3.5 min-w-0">
            <span class="inline-block text-xs text-gold border border-gold rounded-full px-2.5 py-0.5 mb-2">サードプレイスとは</span>
            <h3 class="font-serif text-xs font-light text-dark group-hover:text-gold transition-colors leading-snug"
                style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
              {{ post.data.title }}
            </h3>
            {% if post.data.description %}
            <p class="text-xs text-muted mt-1.5 leading-relaxed"
               style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
              {{ post.data.description }}
            </p>
            {% endif %}
          </div>
        </a>
        {% endfor %}
      </div>

      {# もっとみるボタン #}
      {% set mobileHiddenCount = collections.aboutArticles.length - 4 %}
      {% set desktopHiddenCount = collections.aboutArticles.length - 6 %}
      {% if mobileHiddenCount > 0 %}
      <div class="text-center mt-7{% if desktopHiddenCount <= 0 %} md:hidden{% endif %}">
        <button id="pillar-more-btn"
                class="inline-flex items-center gap-2 border border-border rounded-full px-7 py-2.5 text-sm text-text hover:border-gold hover:text-gold transition-all bg-white shadow-sm">
          もっとみる（<span class="md:hidden">{{ mobileHiddenCount }}</span><span class="hidden md:inline">{{ desktopHiddenCount }}</span>件）
        </button>
      </div>
      {% endif %}

    </div>
  </div>
  {% endif %}

  <script>
  (function() {
    var btn = document.getElementById('pillar-more-btn');
    if (!btn) return;
    btn.addEventListener('click', function() {
      document.querySelectorAll('.pillar-extra').forEach(function(el) {
        el.classList.remove('hidden');
      });
      btn.style.display = 'none';
    });
  })();
  </script>

  {# 最新記事 #}
  {% set latestArticles = collections.articles | head(8) %}
  {% if latestArticles and latestArticles.length %}
  <div class="mb-20" data-aos="fade-up">
    <h2 class="font-serif text-2xl font-light text-dark mb-6">最新記事</h2>

    {# フィーチャー記事（1件目） #}
    {% set featured = latestArticles[0] %}
    {% set featuredCat = categories | findCategoryBySlug(featured.data.category_slug) %}
    <a href="{{ featured.url }}" class="group flex gap-4 rounded-xl overflow-hidden border border-border hover:border-gold shadow-sm hover:shadow-md bg-white transition-all mb-4 p-4">
      {% if featured.data.thumbnail %}
      <div class="shrink-0 w-36 h-28 rounded-lg overflow-hidden">
        <img src="{{ featured.data.thumbnail }}" alt="{{ featured.data.title }}"
             class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-500"
             loading="lazy" decoding="async">
      </div>
      {% endif %}
      <div class="min-w-0 flex flex-col justify-center">
        <div class="flex items-center gap-2 mb-2">
          <span class="inline-block text-xs text-gold border border-gold rounded-full px-2.5 py-0.5 w-fit">
            {% if featuredCat %}{{ featuredCat.name_ja }}{% elif featured.data.category_slug == "about" %}サードプレイスとは{% endif %}
          </span>
          <span class="new-badge hidden bg-[#6B4F3A] text-white text-[10px] font-medium tracking-widest px-2.5 py-0.5 rounded-full" data-publish="{{ featured.date | dateISO }}">NEW</span>
        </div>
        <h3 class="font-serif text-sm font-light text-dark group-hover:text-gold transition-colors leading-snug mb-2">{{ featured.data.title }}</h3>
        {% if featured.data.description %}
        <p class="text-xs text-muted leading-relaxed" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{{ featured.data.description }}</p>
        {% endif %}
      </div>
    </a>

    {# リスト記事（2件目以降） #}
    <div class="border border-border rounded-xl bg-white overflow-hidden shadow-sm mb-6" style="max-height:220px;overflow-y:auto;">
      {% for post in latestArticles %}
      {% if loop.index > 1 %}
      {% set postCat = categories | findCategoryBySlug(post.data.category_slug) %}
      <a href="{{ post.url }}" class="group flex items-center gap-3 px-4 py-3 hover:bg-ivory transition-colors{% if not loop.last %} border-b border-border{% endif %}">
        <div class="shrink-0 w-10 h-10 rounded-md overflow-hidden bg-border">
          {% if post.data.thumbnail %}
          <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
               loading="lazy" decoding="async">
          {% endif %}
        </div>
        <h3 class="font-serif text-xs font-light text-dark group-hover:text-gold transition-colors leading-snug min-w-0 truncate flex-1">
          <span class="new-badge hidden inline-block align-middle bg-[#6B4F3A] text-white text-[9px] font-medium tracking-widest px-2 py-0.5 rounded-full mr-1.5" data-publish="{{ post.date | dateISO }}">NEW</span>{{ post.data.title }}</h3>
        <div class="shrink-0 flex items-center gap-3">
          <span class="text-xs text-muted hidden sm:block">
            {% if postCat %}{{ postCat.name_ja }}{% elif post.data.category_slug == "about" %}サードプレイスとは{% endif %}
          </span>
          <span class="text-xs text-muted whitespace-nowrap">{{ post.date | dateJa }}</span>
        </div>
      </a>
      {% endif %}
      {% endfor %}
    </div>

    {# 記事一覧ボタン #}
    <div class="text-center">
      <a href="/stories/about/" class="inline-flex items-center gap-2 bg-[#6B4F3A] hover:bg-[#5a4030] text-white text-sm px-8 py-3 rounded-full transition-colors">
        記事一覧はこちら →
      </a>
    </div>

  </div>
  {% endif %}

  <script>
  (function() {
    const today = new Date();
    today.setHours(0, 0, 0, 0);
    document.querySelectorAll('.new-badge').forEach(function(badge) {
      const pub = new Date(badge.dataset.publish);
      pub.setHours(0, 0, 0, 0);
      const diff = (today - pub) / (1000 * 60 * 60 * 24);
      if (diff <= 3) badge.classList.remove('hidden');
    });
  })();
  </script>

  {# 15カテゴリナビ #}
  <div class="mb-20" data-aos="fade-up">
    <h2 class="font-serif text-xl font-light text-dark mb-6">カテゴリ</h2>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
      {% for cat in categories %}
      <a href="/stories/{{ cat.slug }}/"
         class="relative block rounded-xl overflow-hidden shadow-sm hover:shadow-md group transition-all aspect-[4/3]">
        {% if cat.image %}
        <img src="{{ cat.image }}" alt="{{ cat.name_ja }}のサードプレイス | Third Place Japan"
             class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
             loading="lazy" decoding="async">
        {% else %}
        <div class="w-full h-full bg-border"></div>
        {% endif %}
        <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent"></div>
        <p class="absolute bottom-0 inset-x-0 text-white text-[11px] text-center px-2 pb-2 leading-tight font-light tracking-wide whitespace-nowrap">{{ cat.name_short or cat.name_ja }}</p>
      </a>
      {% endfor %}
    </div>
  </div>

  {# 認証店舗リンク #}
  {% set published = venues | publishedVenues %}
  {% if published.length %}
  <div data-aos="fade-up">
    <div class="flex items-center justify-between mb-8">
      <h2 class="font-serif text-xl font-light text-dark">認証店舗</h2>
      <a href="/stories/certified/" class="text-xs text-muted hover:text-gold transition-colors">すべて見る →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {% for v in published | sortByGrade | head(3) %}
      {% set cardVenue = v %}{% include "venue-card.njk" %}
      {% endfor %}
    </div>
  </div>
  {% endif %}

</section>

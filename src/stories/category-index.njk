---
pagination:
  data: categories
  size: 1
  alias: cat
permalink: "/stories/{{ cat.slug }}/"
eleventyComputed:
  title: "{{ cat.name_ja }}"
  description: "Third Place Japanが評価した{{ cat.name_ja }}の記事一覧。サードプレイスとしての視点から、日本各地の{{ cat.name_ja }}を紹介します。"
  canonical: "/stories/{{ cat.slug }}/"
---

{# BreadcrumbList JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Third Place Japan", "item": "{{ site.url }}" },
    { "@type": "ListItem", "position": 2, "name": "Stories", "item": "{{ site.url }}/stories/" },
    { "@type": "ListItem", "position": 3, "name": "{{ cat.name_ja }}", "item": "{{ site.url }}/stories/{{ cat.slug }}/" }
  ]
}
</script>

{# CollectionPage JSON-LD #}
{% set catArticles = collections.articles | articlesByCategory(cat.slug) %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "{{ cat.name_ja }} | Third Place Japan Stories",
  "description": "Third Place Japanが評価した{{ cat.name_ja }}の記事一覧。サードプレイスとしての視点から、日本各地の{{ cat.name_ja }}を紹介します。",
  "url": "{{ site.url }}/stories/{{ cat.slug }}/",
  "inLanguage": "ja",
  "publisher": {
    "@type": "Organization",
    "name": "Third Place Japan",
    "url": "{{ site.url }}"
  }{% if catArticles and catArticles.length %},
  "hasPart": [
    {% for post in catArticles | head(10) %}
    {
      "@type": "Article",
      "headline": "{{ post.data.title | replace('"', '\\"') }}",
      "url": "{{ site.url }}{{ post.url }}"
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]{% endif %}
}
</script>

{# FAQPage JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Third Place Japanが評価する{{ cat.name_ja }}とはどのような施設ですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Third Place Japanが評価する{{ cat.name_ja }}は、単なる飲食・サービス提供の場ではなく、居心地・静寂性・特別感など7軸の基準で「いる体験・居場所としての価値」が高い施設です。TPJ編集部が独自に評価・認証した施設のみを掲載しています。"
      }
    },
    {
      "@type": "Question",
      "name": "{{ cat.name_ja }}のTPJセレクト店舗を探すにはどうすればいいですか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Third Place Japan Storiesのセレクト店舗ページ（{{ site.url }}/stories/select/）から業種・エリアで絞り込んで探せます。{{ cat.name_ja }}カテゴリのTPJセレクト店舗は、7軸評価で一定水準を超えた施設のみが掲載されています。"
      }
    }
  ]
}
</script>

<div class="max-w-6xl mx-auto px-6 pt-16 pb-10">

  <nav class="flex items-center gap-2 text-xs text-muted mb-12">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span>／</span>
    <span>{{ cat.name_ja }}</span>
  </nav>

  {% if cat.image %}
  <div class="w-full overflow-hidden mb-16 relative" style="height: 280px" data-aos="fade-up">
    <img src="{{ cat.image }}" alt="{{ cat.name_ja }}のサードプレイス | Third Place Japan"
         class="w-full h-full object-cover" loading="lazy" decoding="async">
    <div class="absolute inset-4 border pointer-events-none" style="border-color: rgba(184,150,12,0.2)"></div>
  </div>
  {% endif %}

  <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_256px] gap-12 lg:gap-16 items-start">

    {# メインコンテンツ #}
    <div class="min-w-0">

      <div class="mb-16" data-aos="fade-up">
        <p class="label mb-4">{{ cat.name_ja }}</p>
        <h1 class="font-serif text-4xl font-light text-dark mb-4">{{ cat.name_ja }}</h1>
        <div class="gold-rule mb-6"></div>
        <p class="text-sm text-muted leading-relaxed">
          サードプレイスとしての視点から見る、{{ cat.name_ja }}の記事一覧。
        </p>
      </div>

      {# 記事一覧 #}
      {% set catArticles = collections.articles | articlesByCategory(cat.slug) %}
      {% if catArticles and catArticles.length %}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6" data-aos="fade-up">
        {% for post in catArticles %}
        <a href="{{ post.url }}" class="group block border border-border hover:border-gold transition-colors">
          {% if post.data.thumbnail %}
          <div class="overflow-hidden aspect-video">
            <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}"
                 class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                 loading="lazy" decoding="async">
          </div>
          {% endif %}
          <div class="p-5">
            <h2 class="font-serif text-base font-light text-dark group-hover:text-gold transition-colors leading-snug">
              {{ post.data.title }}
            </h2>
            {% if post.data.description %}
            <p class="text-xs text-muted mt-2 leading-relaxed line-clamp-2">{{ post.data.description }}</p>
            {% endif %}
            <p class="text-xs text-muted mt-2">{{ post.date | dateJa }}</p>
          </div>
        </a>
        {% endfor %}
      </div>
      {% else %}
      <div class="py-16 text-center" data-aos="fade-up">
        <p class="font-serif text-xl font-light text-dark mb-4">準備中です</p>
        <p class="text-sm text-muted mb-8">このカテゴリの記事を順次公開予定です。</p>
        <a href="/stories/" class="label hover:text-dark transition-colors">← Storiesトップへ</a>
      </div>
      {% endif %}

      {# このカテゴリのセレクト店舗 #}
      {% set catVenues = venues | venuesByCategory(cat.slug) | sortByGrade %}
      {% if catVenues.length %}
      <section class="mt-20 pt-10 border-t border-border" data-aos="fade-up">
        <div class="flex items-center justify-between mb-8">
          <p class="label">{{ cat.name_ja }}のセレクト店舗</p>
          <a href="/stories/select/" class="text-xs text-muted hover:text-gold transition-colors">TPJセレクト一覧 →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {% for v in catVenues | head(3) %}
          {% set cardVenue = v %}{% include "venue-card.njk" %}
          {% endfor %}
        </div>
      </section>
      {% endif %}

    {# FAQ セクション #}
    <section class="mt-20 pt-10 border-t border-border" data-aos="fade-up">
      <div class="flex items-center gap-3 mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted shrink-0" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><path d="M12 17h.01"/></svg>
        <h2 class="font-serif text-xl font-light text-dark">よくある質問</h2>
      </div>
      <div class="space-y-3">
        <div class="bg-white border border-gold/30 rounded-xl overflow-hidden shadow-sm">
          <button class="faq-btn w-full flex items-center justify-between px-6 py-4 text-left gap-4" aria-expanded="true">
            <span class="font-serif text-sm font-light text-dark leading-snug">Third Place Japanが評価する{{ cat.name_ja }}とはどのような施設ですか？</span>
            <i data-lucide="chevron-down" class="w-4 h-4 text-muted shrink-0 transition-transform duration-300" style="transform:rotate(180deg)"></i>
          </button>
          <div class="faq-body px-6 pb-5">
            <div class="gold-rule mb-4"></div>
            <p class="text-sm text-muted leading-relaxed">Third Place Japanが評価する{{ cat.name_ja }}は、単なるサービス提供の場ではなく、居心地・静寂性・特別感など7軸の基準で「いる体験・居場所としての価値」が高い施設です。TPJ編集部が独自に評価・認証した施設のみを掲載しています。</p>
          </div>
        </div>
        <div class="bg-white border border-gold/30 rounded-xl overflow-hidden shadow-sm">
          <button class="faq-btn w-full flex items-center justify-between px-6 py-4 text-left gap-4" aria-expanded="true">
            <span class="font-serif text-sm font-light text-dark leading-snug">{{ cat.name_ja }}のTPJセレクト店舗を探すにはどうすればいいですか？</span>
            <i data-lucide="chevron-down" class="w-4 h-4 text-muted shrink-0 transition-transform duration-300" style="transform:rotate(180deg)"></i>
          </button>
          <div class="faq-body px-6 pb-5">
            <div class="gold-rule mb-4"></div>
            <p class="text-sm text-muted leading-relaxed">Third Place Japan Storiesのセレクト店舗ページから業種・エリアで絞り込んで探せます。{{ cat.name_ja }}カテゴリのTPJセレクト店舗は、7軸評価で一定水準を超えた施設のみが掲載されています。</p>
          </div>
        </div>
        <div class="bg-white border border-gold/30 rounded-xl overflow-hidden shadow-sm">
          <button class="faq-btn w-full flex items-center justify-between px-6 py-4 text-left gap-4" aria-expanded="true">
            <span class="font-serif text-sm font-light text-dark leading-snug">{{ cat.name_ja }}でサードプレイスを選ぶ際のポイントは何ですか？</span>
            <i data-lucide="chevron-down" class="w-4 h-4 text-muted shrink-0 transition-transform duration-300" style="transform:rotate(180deg)"></i>
          </button>
          <div class="faq-body px-6 pb-5">
            <div class="gold-rule mb-4"></div>
            <p class="text-sm text-muted leading-relaxed">TPJが重視するのは「その場所にいる体験の質」です。静寂性（周囲の音・プライバシー）、居心地（照明・素材・温度感）、再訪したくなるか、という3点が{{ cat.name_ja }}選びの基本的な指標になります。</p>
          </div>
        </div>
      </div>
    </section>
    <script>
    document.querySelectorAll('.faq-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var body = this.nextElementSibling;
        var icon = this.querySelector('[data-lucide]');
        var isOpen = this.getAttribute('aria-expanded') === 'true';
        body.classList.toggle('hidden', isOpen);
        this.setAttribute('aria-expanded', !isOpen);
        if (icon) icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      });
    });
    </script>

    </div>

    {# サイドバー #}
    <aside class="hidden lg:block">
      <div class="sticky top-24 space-y-8">

        {# カテゴリ #}
        <div class="rounded-xl p-5" style="border:1px solid rgba(184,150,12,0.5);background-color:#ffffff;">
          <p class="label mb-4">カテゴリ</p>
          <ul class="space-y-0">
            {% for c in categories %}
            <li class="border-b border-border last:border-0">
              <a href="/stories/{{ c.slug }}/"
                 class="text-xs leading-snug block py-1.5 transition-colors
                 {% if c.slug == cat.slug %}text-gold font-medium{% else %}text-muted hover:text-gold{% endif %}">
                {{ c.name_ja }}
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>

        {# 最新記事 #}
        {% set latestPosts = collections.articles | head(5) %}
        {% if latestPosts and latestPosts.length %}
        <div class="rounded-xl p-5" style="border:1px solid rgba(184,150,12,0.5);background-color:#ffffff;">
          <p class="label mb-4">最新記事</p>
          <ul class="space-y-4">
            {% for post in latestPosts %}
            <li>
              <a href="{{ post.url }}" class="group block">
                {% set postCat = categories | findCategoryBySlug(post.data.category_slug) %}
                {% if postCat %}
                <p class="text-xs text-gold mb-0.5">{{ postCat.name_ja }}</p>
                {% elif post.data.category_slug == "about" %}
                <p class="text-xs text-gold mb-0.5">サードプレイスとは</p>
                {% endif %}
                <p class="text-xs text-text group-hover:text-gold transition-colors leading-snug">{{ post.data.title }}</p>
                <p class="text-xs text-muted mt-1">{{ post.date | dateJa }}</p>
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endif %}

        {# サードプレイスとは #}
        {% if collections.aboutArticles and collections.aboutArticles.length %}
        <div class="rounded-xl p-5" style="border:1px solid rgba(184,150,12,0.5);background-color:#ffffff;">
          <p class="label mb-4">サードプレイスとは</p>
          <ul class="space-y-0">
            {% for post in collections.aboutArticles | head(5) %}
            <li class="border-b border-border last:border-0">
              <a href="{{ post.url }}" class="text-xs text-muted hover:text-gold transition-colors leading-snug block py-1.5">
                {{ post.data.title }}
              </a>
            </li>
            {% endfor %}
          </ul>
          <a href="/stories/about/" class="text-xs text-muted hover:text-gold transition-colors mt-3 block">すべて見る →</a>
        </div>
        {% endif %}

      </div>
    </aside>

  </div>
</div>

<footer class="mt-14 border-t border-border">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8 mb-10">

      <!-- ① 最新記事 -->
      <div class="col-span-2 md:col-span-1">
        <p class="label mb-4">最新記事</p>
        <ul class="space-y-2 text-xs text-muted">
          {% set latestPosts = collections.articles | rejectLang("en") | head(4) %}
          {% for post in latestPosts %}
          <li><a href="{{ post.url }}" class="hover:text-gold transition-colors line-clamp-1">{{ post.data.title }}</a></li>
          {% endfor %}
        </ul>
        <a href="/stories/latest/" class="inline-block mt-3 text-xs text-gold hover:underline">記事一覧 →</a>
      </div>

      <!-- ② サードプレイスガイド -->
      <div>
        <p class="label mb-4">サードプレイスガイド</p>
        <ul class="space-y-2 text-xs text-muted">
          {% set guidePosts = collections.aboutArticles | head(4) %}
          {% for post in guidePosts %}
          <li><a href="{{ post.url }}" class="hover:text-gold transition-colors line-clamp-1">{{ post.data.title }}</a></li>
          {% endfor %}
        </ul>
        <a href="/stories/about/" class="inline-block mt-3 text-xs text-gold hover:underline">サードプレイスガイド一覧 →</a>
      </div>

      <!-- ③ カテゴリ -->
      <div class="col-span-2 md:col-span-1">
        <p class="label mb-4">カテゴリ</p>
        <ul class="space-y-2 text-xs text-muted grid grid-cols-2 md:grid-cols-1 gap-x-4">
          {% for cat in categories %}
          <li><a href="/stories/{{ cat.slug }}/" class="hover:text-gold transition-colors">{{ cat.name_ja }}</a></li>
          {% endfor %}
        </ul>
      </div>

      <!-- ④ エリア -->
      <div>
        <p class="label mb-4">エリア</p>
        <ul class="text-xs text-muted grid grid-cols-2 gap-x-3 gap-y-2">
          <li><a href="/stories/area/tokyo/shibuya-ku/" class="hover:text-gold transition-colors">渋谷区</a></li>
          <li><a href="/stories/area/tokyo/minato-ku/" class="hover:text-gold transition-colors">港区</a></li>
          <li><a href="/stories/area/tokyo/shinjuku-ku/" class="hover:text-gold transition-colors">新宿区</a></li>
          <li><a href="/stories/area/tokyo/chuo-ku/" class="hover:text-gold transition-colors">中央区</a></li>
          <li><a href="/stories/area/tokyo/meguro-ku/" class="hover:text-gold transition-colors">目黒区</a></li>
          <li><a href="/stories/area/tokyo/setagaya-ku/" class="hover:text-gold transition-colors">世田谷区</a></li>
          <li><a href="/stories/area/tokyo/chiyoda-ku/" class="hover:text-gold transition-colors">千代田区</a></li>
          <li><a href="/stories/area/tokyo/toshima-ku/" class="hover:text-gold transition-colors">豊島区</a></li>
          <li><a href="/stories/area/tokyo/taito-ku/" class="hover:text-gold transition-colors">台東区</a></li>
          <li><a href="/stories/area/tokyo/koto-ku/" class="hover:text-gold transition-colors">江東区</a></li>
          <li class="opacity-50 col-span-2 mt-1">エリア拡大中</li>
        </ul>
        <a href="/stories/area/" class="inline-block mt-3 text-xs text-gold hover:underline">場所をめぐる →</a>
      </div>

      <!-- ⑤ TPJセレクト -->
      <div>
        <p class="label mb-4">TPJセレクト</p>
        <ul class="space-y-2 text-xs text-muted">
          <li><a href="/stories/select/" class="hover:text-gold transition-colors">TPJセレクト一覧</a></li>
        </ul>
      </div>

    </div>
    <div class="pt-8 border-t border-border flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <p class="font-serif text-xs text-muted tracking-wider">Third Place Japan</p>
      <a href="/en/stories/" class="inline-flex items-center gap-1.5 text-xs border border-gold/40 text-muted rounded-full px-3 py-1 hover:border-gold hover:text-gold transition-all">
        <i data-lucide="globe" class="w-3 h-3"></i>
        English
      </a>
      <p class="text-xs text-muted">© Third Place Japan. All rights reserved.</p>
    </div>
  </div>
</footer>

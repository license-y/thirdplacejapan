<footer class="mt-24 border-t border-border">
  <div class="max-w-6xl mx-auto px-6 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-10">
      <div>
        <p class="label mb-4">Stories</p>
        <ul class="space-y-2 text-xs text-muted">
          <li><a href="/stories/about/" class="hover:text-gold transition-colors">読み物</a></li>
          <li><a href="/stories/area/" class="hover:text-gold transition-colors">場所をめぐる</a></li>
          <li><a href="/stories/certified/" class="hover:text-gold transition-colors">認証店舗一覧</a></li>
          <li><a href="/en/stories/" class="hover:text-gold transition-colors">English</a></li>
        </ul>
      </div>
      <div>
        <p class="label mb-4">カテゴリ</p>
        <ul class="space-y-2 text-xs text-muted">
          {% for cat in categories | head(5) %}
          <li><a href="/stories/{{ cat.slug }}/" class="hover:text-gold transition-colors">{{ cat.name_ja }}</a></li>
          {% endfor %}
        </ul>
      </div>
      <div>
        <p class="label mb-4">TPJとは</p>
        <ul class="space-y-2 text-xs text-muted">
          <li><a href="/" class="hover:text-gold transition-colors">Third Place Japan</a></li>
          <li><a href="/certification/" class="hover:text-gold transition-colors">認証制度について</a></li>
        </ul>
      </div>
    </div>
    <div class="pt-8 border-t border-border flex flex-col md:flex-row items-start md:items-center justify-between gap-4">
      <p class="font-serif text-xs text-muted tracking-wider">Third Place Japan</p>
      <p class="text-xs text-muted">© Third Place Japan. All rights reserved.</p>
    </div>
  </div>
</footer>

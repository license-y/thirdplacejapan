{# venue-card.njk — Usage: {% set cardVenue = venue %}{% include "venue-card.njk" %} #}
<a href="/stories/select/{{ cardVenue.slug }}/" class="venue-card block p-4 md:p-6 bg-white border border-border hover:border-gold hover:bg-ivory transition-colors group">
  <div class="flex items-start justify-between mb-3">
    <span class="label text-xs">{{ cardVenue.category }}</span>
  </div>
  <h3 class="font-serif text-lg font-light text-dark mb-1.5 group-hover:text-gold transition-colors">
    {{ cardVenue.name }}
  </h3>
  <p class="text-xs text-muted mb-3">
    {{ cardVenue.area_primary.prefecture }} {{ cardVenue.area_primary.area }}
  </p>
  <p class="text-sm text-text leading-relaxed line-clamp-2 md:line-clamp-3">{{ cardVenue.citation }}</p>
  <div class="mt-3 flex flex-wrap gap-1.5 md:gap-2">
    <span class="text-xs text-gold border border-gold px-3 py-0.5 rounded-full">{{ cardVenue.axes_primary }}</span>
    {% for ax in cardVenue.axes_secondary %}
    <span class="text-xs text-muted border border-border px-3 py-0.5 rounded-full">{{ ax }}</span>
    {% endfor %}
  </div>
</a>

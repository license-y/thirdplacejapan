---
layout: journal.njk
og_type: "article"
---

{# LocalBusiness + 7軸スコア JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "{{ venue.name }}",
  "description": "{{ venue.citation | replace('"', '\\"') }}",
  "image": "{{ site.url }}{{ venue.image }}",
  "url": "{{ site.url }}/journal/certified/{{ venue.slug }}/",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "{{ venue.area_primary.area }}",
    "addressRegion": "{{ venue.area_primary.prefecture }}",
    "addressCountry": "JP"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": {{ venue.lat }},
    "longitude": {{ venue.lng }}
  },
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "TPJ Certification Grade", "value": "{{ venue.grade }}" },
    { "@type": "PropertyValue", "name": "TPJ Certified Date", "value": "{{ venue.certified_date }}" },
    { "@type": "PropertyValue", "name": "TPJ Primary Evaluation Axis", "value": "{{ venue.axes_primary }}" },
    { "@type": "PropertyValue", "name": "TPJ Score: Comfort", "value": {{ venue.scores.comfort }} },
    { "@type": "PropertyValue", "name": "TPJ Score: Silence", "value": {{ venue.scores.silence }} },
    { "@type": "PropertyValue", "name": "TPJ Score: Special", "value": {{ venue.scores.special }} },
    { "@type": "PropertyValue", "name": "TPJ Score: Revisit", "value": {{ venue.scores.revisit }} },
    { "@type": "PropertyValue", "name": "TPJ Score: Inbound", "value": {{ venue.scores.inbound }} },
    { "@type": "PropertyValue", "name": "TPJ Score: Record", "value": {{ venue.scores.record }} },
    { "@type": "PropertyValue", "name": "TPJ Score: Story", "value": {{ venue.scores.story }} }
  ]
}
</script>

{# BreadcrumbList JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Journal", "item": "{{ site.url }}/journal/" },
    { "@type": "ListItem", "position": 2, "name": "認証店舗", "item": "{{ site.url }}/journal/certified/" },
    { "@type": "ListItem", "position": 3, "name": "{{ venue.name }}", "item": "{{ site.url }}/journal/certified/{{ venue.slug }}/" }
  ]
}
</script>

<article class="max-w-2xl mx-auto px-6 py-16 md:py-24">

  {# パンくず #}
  <nav class="flex items-center gap-2 text-xs text-muted mb-12" aria-label="パンくず">
    <a href="/journal/" class="hover:text-gold transition-colors">Journal</a>
    <span class="text-border">／</span>
    <a href="/journal/certified/" class="hover:text-gold transition-colors">認証店舗</a>
    <span class="text-border">／</span>
    <span>{{ venue.name }}</span>
  </nav>

  {# グレードバッジ + カテゴリ #}
  <div class="flex items-center gap-4 mb-6" data-aos="fade-up">
    <span class="grade-badge">{{ venue.grade }}</span>
    <span class="label">{{ venue.category }}</span>
  </div>

  {# 店舗名 #}
  <h1 class="font-serif text-3xl md:text-4xl font-light text-dark mb-4 leading-tight" data-aos="fade-up">
    {{ venue.name }}
  </h1>

  {# エリア #}
  <p class="text-sm text-muted mb-10" data-aos="fade-up">
    <a href="/journal/area/{{ venue.area_primary.prefecture_slug }}/{{ venue.area_primary.city_slug }}/{{ venue.area_primary.area_slug }}/"
       class="hover:text-gold transition-colors">
      {{ venue.area_primary.prefecture }} {{ venue.area_primary.area }}
    </a>

    <a href="/journal/area/{{ venue.area_primary.prefecture_slug }}/{{ venue.area_primary.city_slug }}/{{ venue.area_primary.area_slug }}/{{ venue.category_slug }}/"
       class="hover:text-gold transition-colors">{{ venue.category }}</a>
  </p>

  {# 引用用一文（AEO核心・AIが引用する一文） #}
  <div class="border-l-2 border-gold pl-6 mb-12 py-1" data-aos="fade-up">
    <p class="font-serif text-base leading-relaxed text-dark">{{ venue.citation }}</p>
  </div>

  {# 7軸スコア #}
  <section class="mb-14" data-aos="fade-up">
    <p class="label mb-6">7軸評価スコア</p>
    <div class="space-y-4">
      {% set axisData = [
        { slug: "comfort", name: "居心地・空間品質", score: venue.scores.comfort },
        { slug: "silence", name: "静寂性・プライバシー", score: venue.scores.silence },
        { slug: "special", name: "特別感・非日常性", score: venue.scores.special },
        { slug: "revisit", name: "再訪・継続価値", score: venue.scores.revisit },
        { slug: "inbound", name: "インバウンド・多言語対応", score: venue.scores.inbound },
        { slug: "record", name: "記録・シェア体験", score: venue.scores.record },
        { slug: "story", name: "ストーリー・背景への共感", score: venue.scores.story }
      ] %}
      {% for ax in axisData %}
      <div class="flex items-center gap-4">
        <span class="text-xs text-muted w-40 shrink-0">{{ ax.name }}</span>
        <div class="axis-score-bar flex-1">
          <div class="axis-score-fill" style="width: {{ ax.score * 10 }}%"></div>
        </div>
        <span class="text-xs text-gold font-light w-6 text-right">{{ ax.score }}</span>
      </div>
      {% endfor %}
    </div>
  </section>

  {# 記事本文 #}
  <div class="prose" data-aos="fade-up">
    {{ content | safe }}
  </div>

  {# 基本情報 #}
  <aside class="mt-16 pt-8 border-t border-border text-sm text-muted space-y-2" data-aos="fade-up">
    <p>{{ venue.area_primary.prefecture }} {{ venue.address }}</p>
    {% if venue.nearest_stations and venue.nearest_stations.length %}
    <p>最寄駅：{{ venue.nearest_stations | join("・") }}</p>
    {% endif %}
    {% if venue.url %}
    <p><a href="{{ venue.url }}" target="_blank" rel="noopener" class="hover:text-gold transition-colors">公式サイト ↗</a></p>
    {% endif %}
    <p class="pt-2 text-xs">Third Place Japan 認証取得：{{ venue.certified_date }}</p>
  </aside>

  {# 認証制度への還流導線 #}
  <div class="mt-16 pt-8 border-t border-border" data-aos="fade-up">
    <p class="text-sm text-muted text-left md:text-center">
      この場所は Third Place Japan 認証店舗です。<br class="hidden md:block">
      <a href="{{ site.main_site_url }}/certification/" class="text-gold hover:underline">認証制度について知る</a>
    </p>
  </div>

  {# 英語版リンク #}
  {% if venue.has_en and lang != "en" %}
  <div class="mt-6 text-center">
    <a href="/en/journal/certified/{{ venue.slug }}/" class="label hover:text-dark transition-colors">
      Read in English
    </a>
  </div>
  {% endif %}

</article>

---
layout: stories.njk
og_type: "article"
---

{# グレード→数値マッピング #}
{%- set gradeNums = {"Certified": 1, "Silver": 2, "Gold": 3, "Platinum": 4, "Flagship": 5} -%}
{%- set gradeLevels = {"certified": 1, "silver": 2, "gold": 3, "platinum": 4, "flagship": 5} -%}
{%- set thisLevel = gradeLevels[venue.grade_slug] or 0 -%}

{# 7軸スコア平均（AggregateRating用） #}
{%- set totalScore = venue.scores.comfort + venue.scores.silence + venue.scores.special + venue.scores.story + venue.scores.revisit + venue.scores.record + venue.scores.inbound -%}
{%- set avgScore = (totalScore / 7) | round(1) -%}

{# LocalBusiness + 7軸スコア JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": {{ venue.name | dump | safe }},
  "description": {{ venue.citation | dump | safe }},
  "image": "{{ site.url }}{{ venue.image }}",
  "url": "{{ site.url }}/stories/select/{{ venue.slug }}/",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": {{ venue.area_primary.area | dump | safe }},
    "addressRegion": {{ venue.area_primary.prefecture | dump | safe }},
    "addressCountry": "JP"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": {{ avgScore }},
    "bestRating": 10,
    "worstRating": 0,
    "ratingCount": 1,
    "reviewCount": 1
  },
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "TPJ認証グレード", "value": {{ venue.grade | dump | safe }} },
    { "@type": "PropertyValue", "name": "TPJ認証取得日", "value": "{{ venue.certified_date }}" },
    { "@type": "PropertyValue", "name": "主評価軸", "value": {{ venue.axes_primary | dump | safe }} },
    { "@type": "PropertyValue", "name": "五感品質・素材スコア", "value": {{ venue.scores.comfort }} },
    { "@type": "PropertyValue", "name": "静けさの再現スコア", "value": {{ venue.scores.silence }} },
    { "@type": "PropertyValue", "name": "特別感・ギフト体験スコア", "value": {{ venue.scores.special }} },
    { "@type": "PropertyValue", "name": "ストーリー継承スコア", "value": {{ venue.scores.story }} },
    { "@type": "PropertyValue", "name": "愛用・回遊価値スコア", "value": {{ venue.scores.revisit }} },
    { "@type": "PropertyValue", "name": "シェア・記録性スコア", "value": {{ venue.scores.record }} },
    { "@type": "PropertyValue", "name": "インバウンド適性スコア", "value": {{ venue.scores.inbound }} }
  ]
  {% if thisLevel >= 1 %},
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": {{ venue.lat }},
    "longitude": {{ venue.lng }}
  }
  {% endif %}
  {% if thisLevel >= 2 and (venue.url or venue.instagram_url) %},
  "sameAs": [{% if venue.url %}{{ venue.url | dump | safe }}{% endif %}{% if venue.url and venue.instagram_url %},{% endif %}{% if venue.instagram_url %}{{ venue.instagram_url | dump | safe }}{% endif %}]
  {% endif %}
  {% if thisLevel >= 2 and venue.opening_hours %},
  "openingHours": {{ venue.opening_hours | dump | safe }}
  {% endif %}
  {% if thisLevel >= 2 and venue.price_range %},
  "priceRange": {{ venue.price_range | dump | safe }}
  {% endif %}
  {% if thisLevel >= 3 and venue.telephone %},
  "telephone": {{ venue.telephone | dump | safe }}
  {% endif %}
  {% if thisLevel >= 3 and venue.menu_url %},
  "hasMenu": {{ venue.menu_url | dump | safe }}
  {% endif %}
  {% if thisLevel >= 3 and venue.serves_cuisine %},
  "servesCuisine": {{ venue.serves_cuisine | dump | safe }}
  {% endif %}
  {% if thisLevel >= 4 and venue.amenity_features %},
  "amenityFeature": [
    {% for f in venue.amenity_features %}
    { "@type": "LocationFeatureSpecification", "name": {{ f | dump | safe }}, "value": true }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
  {% endif %}
  {% if thisLevel >= 4 and venue.smoking_allowed !== undefined %},
  "smokingAllowed": {{ venue.smoking_allowed }}
  {% endif %}
}
</script>

{# Review + reviewRating JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": {
    "@type": "LocalBusiness",
    "name": {{ venue.name | dump | safe }},
    "address": {
      "@type": "PostalAddress",
      "addressLocality": {{ venue.area_primary.area | dump | safe }},
      "addressRegion": {{ venue.area_primary.prefecture | dump | safe }},
      "addressCountry": "JP"
    }
  },
  "author": {
    "@type": "Organization",
    "name": "サードプレイスジャパン編集部",
    "url": "{{ site.url }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Third Place Japan",
    "url": "{{ site.url }}"
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": {{ gradeNums[venue.grade] or 1 }},
    "bestRating": 5,
    "worstRating": 1,
    "description": "TPJ認証グレード {{ venue.grade }}"
  },
  "reviewBody": {{ venue.citation | dump | safe }},
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "五感品質・素材", "value": {{ venue.scores.comfort }} },
    { "@type": "PropertyValue", "name": "静けさの再現", "value": {{ venue.scores.silence }} },
    { "@type": "PropertyValue", "name": "特別感・ギフト体験", "value": {{ venue.scores.special }} },
    { "@type": "PropertyValue", "name": "ストーリー継承", "value": {{ venue.scores.story }} },
    { "@type": "PropertyValue", "name": "愛用・回遊価値", "value": {{ venue.scores.revisit }} },
    { "@type": "PropertyValue", "name": "シェア・記録性", "value": {{ venue.scores.record }} },
    { "@type": "PropertyValue", "name": "インバウンド適性", "value": {{ venue.scores.inbound }} }
  ],
  "url": "{{ site.url }}/stories/select/{{ venue.slug }}/"
}
</script>

{# BreadcrumbList JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Third Place Japan", "item": "{{ site.url }}" },
    { "@type": "ListItem", "position": 2, "name": "Stories", "item": "{{ site.url }}/stories/" },
    { "@type": "ListItem", "position": 3, "name": {% if venue.grade_slug == "flagship" %}"Flagship"{% else %}"TPJセレクト"{% endif %}, "item": "{{ site.url }}/stories/select/" },
    { "@type": "ListItem", "position": 4, "name": "{{ venue.name }}", "item": "{{ site.url }}/stories/select/{{ venue.slug }}/" }
  ]
}
</script>

{# FAQPage JSON-LD（venue.faq が存在する場合のみ） #}
{% if venue.faq and venue.faq.length %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in venue.faq %}
    {
      "@type": "Question",
      "name": {{ item.q | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ item.a | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

<article class="max-w-2xl mx-auto px-6 py-16 md:py-24">

  {# パンくず #}
  <nav class="flex items-center gap-2 text-xs text-muted mb-12" aria-label="パンくず">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span class="text-border">／</span>
    <a href="/stories/select/" class="hover:text-gold transition-colors">{% if venue.grade_slug == "flagship" %}Flagship{% else %}TPJセレクト{% endif %}</a>
    <span class="text-border">／</span>
    <span>{{ venue.name }}</span>
  </nav>

  {# カテゴリ+グレードバッジ #}
  <div class="flex items-center gap-3 flex-wrap mb-6" data-aos="fade-up">
    <span class="label">{{ venue.category }}</span>
    {# グレードバッジ #}
    {% if venue.grade_slug == "flagship" %}
      <span class="inline-flex items-center gap-1 text-xs font-light tracking-widest px-2.5 py-0.5 rounded-full border border-stone-300 text-stone-400">
        <svg xmlns="http://www.w3.org/2000/svg" width="9" height="9" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
        Flagship
      </span>
    {% elif venue.grade_slug == "platinum" %}
      <span class="text-xs font-light tracking-widest px-2.5 py-0.5 rounded-full border border-stone-300 text-stone-400">Platinum</span>
    {% elif venue.grade_slug == "gold" %}
      <span class="text-xs font-light tracking-widest px-2.5 py-0.5 rounded-full border border-gold/40 text-gold/70">Gold</span>
    {% elif venue.grade_slug == "silver" %}
      <span class="text-xs font-light tracking-widest px-2.5 py-0.5 rounded-full border border-stone-300 text-stone-400">Silver</span>
    {% elif venue.grade_slug == "certified" %}
      <span class="text-xs font-light tracking-widest px-2.5 py-0.5 rounded-full border border-stone-300 text-stone-400">Certified</span>
    {% else %}
      <span class="inline-flex items-center gap-1.5 text-xs text-muted border border-border px-2.5 py-0.5 rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        TPJセレクト
      </span>
    {% endif %}
  </div>

  {# 店舗名 #}
  <h1 class="font-serif text-3xl md:text-4xl font-light text-dark mb-4 leading-tight" data-aos="fade-up">
    {{ venue.name }}
  </h1>

  {# エリア #}
  <p class="text-sm text-muted mb-10" data-aos="fade-up">
    <a href="/stories/area/{{ venue.area_primary.prefecture_slug }}/{{ venue.area_primary.city_slug }}/{{ venue.area_primary.area_slug }}/"
       class="hover:text-gold transition-colors">
      {{ venue.area_primary.prefecture }} {{ venue.area_primary.area }}
    </a>
    ·
    <a href="/stories/area/{{ venue.area_primary.prefecture_slug }}/{{ venue.area_primary.city_slug }}/{{ venue.area_primary.area_slug }}/{{ venue.category_slug }}/"
       class="hover:text-gold transition-colors">{{ venue.category }}</a>
  </p>

  {# 施設写真（専用画像が設定されている施設のみ表示。共通デフォルト画像の使い回しはしない） #}
  {% set hasDedicatedImage = venue.image and venue.image != "/assets/images/main/japan-cafe-interior-hero.webp" %}
  {% if hasDedicatedImage %}
  <div class="mb-12 rounded-xl overflow-hidden" data-aos="fade-up">
    <img src="{{ venue.image }}" alt="{{ venue.name }} | Third Place Japan" class="w-full aspect-video object-cover" loading="lazy" decoding="async">
  </div>
  {% endif %}

  {# 引用用一文（AEO核心・AIが引用する一文） #}
  <div class="border-l-2 border-gold pl-6 mb-12 py-1" data-aos="fade-up">
    <p class="font-serif text-base leading-relaxed text-dark">{{ venue.citation }}</p>
  </div>

  {# 施設情報（営業時間・価格帯・電話）— TPJセレクトは非表示 #}
  {% if (venue.opening_hours_display or venue.price_range or venue.telephone) and venue.grade_slug != "select" %}
  {% set hasRoast = venue.tags and "自家焙煎機" in venue.tags %}
  {% set hasBeanVarieties = venue.bean_varieties_count %}
  {% set hasWifiPower = venue.amenity_features and "Wi-Fi" in venue.amenity_features and "電源" in venue.amenity_features %}
  {% set hasGlutenFree = venue.tags and "グルテンフリー" in venue.tags %}
  {% set hasPetFriendly = venue.tags and "店内ペット同伴可" in venue.tags %}
  {% set showNonSmoking = venue.smoking_allowed == false %}
  {% set hasAmenityBadge = hasRoast or hasBeanVarieties or hasWifiPower or hasGlutenFree or hasPetFriendly or showNonSmoking %}
  <div class="mb-12 bg-stone-50 rounded-xl px-5 py-4" data-aos="fade-up">
    <div class="flex flex-wrap gap-x-8 gap-y-3 text-sm">
      {% if venue.opening_hours_display %}
      <div class="flex items-center gap-2" style="color:#3D2B1F;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted shrink-0" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        <span>{{ venue.opening_hours_display }}</span>
      </div>
      {% endif %}
      {% if venue.price_range %}
      <div class="flex items-center gap-2" style="color:#3D2B1F;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted shrink-0" aria-hidden="true"><line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        <span>{{ venue.price_range }}</span>
      </div>
      {% endif %}
      {% if venue.telephone %}
      <div class="flex items-center gap-2" style="color:#3D2B1F;">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted shrink-0" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.89 12.35 19.79 19.79 0 0 1 1.71 3.72 2 2 0 0 1 3.7 1.54h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l.87-.87a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <a href="tel:{{ venue.telephone }}" class="hover:text-gold transition-colors">{{ venue.telephone }}</a>
      </div>
      {% endif %}
    </div>
    {% if hasAmenityBadge %}
    <div class="grid grid-cols-3 gap-2 mt-3 pt-3 border-t border-stone-200">
      {% if hasRoast %}
      <span class="flex items-center justify-center gap-1.5 text-xs px-3 py-2 rounded-full bg-white border border-gold/50" style="color:#3D2B1F;">
        <i data-lucide="coffee" class="w-3.5 h-3.5 shrink-0"></i>自家焙煎コーヒー専門店
      </span>
      {% endif %}
      {% if hasBeanVarieties %}
      <span class="flex items-center justify-center gap-1.5 text-xs px-3 py-2 rounded-full bg-white border border-gold/50" style="color:#3D2B1F;">
        <i data-lucide="bean" class="w-3.5 h-3.5 shrink-0"></i>{{ venue.bean_varieties_count }}種類のコーヒー豆
      </span>
      {% endif %}
      {% if hasWifiPower %}
      <span class="flex items-center justify-center gap-1.5 text-xs px-3 py-2 rounded-full bg-white border border-gold/50" style="color:#3D2B1F;">
        <i data-lucide="wifi" class="w-3.5 h-3.5 shrink-0"></i>Wi-Fi・電源完備
      </span>
      {% endif %}
      {% if hasGlutenFree %}
      <span class="flex items-center justify-center gap-1.5 text-xs px-3 py-2 rounded-full bg-white border border-gold/50" style="color:#3D2B1F;">
        <i data-lucide="wheat-off" class="w-3.5 h-3.5 shrink-0"></i>グルテンフリー対応
      </span>
      {% endif %}
      {% if hasPetFriendly %}
      <span class="flex items-center justify-center gap-1.5 text-xs px-3 py-2 rounded-full bg-white border border-gold/50" style="color:#3D2B1F;">
        <i data-lucide="paw-print" class="w-3.5 h-3.5 shrink-0"></i>店内ペット同伴可
      </span>
      {% endif %}
      {% if showNonSmoking %}
      <span class="flex items-center justify-center gap-1.5 text-xs px-3 py-2 rounded-full bg-white border border-gold/50" style="color:#3D2B1F;">
        <i data-lucide="cigarette-off" class="w-3.5 h-3.5 shrink-0"></i>禁煙
      </span>
      {% endif %}
    </div>
    {% endif %}
  </div>
  {% endif %}

  {# Flagship専用：実証店舗セクション #}
  {% if venue.grade_slug == "flagship" %}
  <section class="mb-12 bg-stone-50 border border-gold/30 rounded-xl px-6 py-6" data-aos="fade-up">
    <p class="label mb-3">Third Place Japanの実証店舗として</p>
    <p class="text-sm leading-relaxed mb-4" style="color:#3D2B1F;">{{ venue.name }}は、Third Place Japanが提唱する「理想の空間づくり」を、実際の店舗として体現・検証する実証店舗です。ここで積み重ねられた知見は、TPJセレクトの評価基準や、今後整備される認証制度の審査基準そのものに反映されています。</p>
    <p class="text-sm leading-relaxed mb-4" style="color:#3D2B1F;">内装設計、動線づくり、静けさを保つための工夫など、この場所で実践されている取り組みの多くは、Third Place Japanが取り組む居場所づくり・空間プロデュースの実例でもあります。「自店舗でも同じような居心地の空間をつくりたい」という方は、法人サイトよりお気軽にご覧ください。</p>
    <a href="{{ site.main_site_url }}/#services" class="inline-flex items-center gap-1.5 text-xs text-gold border border-gold/50 rounded-full px-4 py-1.5 hover:border-gold transition-colors">
      居場所づくり・空間プロデュースについて詳しくみる →
    </a>
  </section>
  {% endif %}

  {# 空間の7基準スコア #}
  <section class="mb-14" data-aos="fade-up">
    <p class="label mb-6">空間の7基準</p>
    <div class="space-y-6">

      {# 【場の質】その場で感じる空間 #}
      <div>
        <p class="text-xs text-muted font-medium mb-3 tracking-wider">【場の質】その場で感じる空間</p>
        <div class="space-y-3">
          {% set axGroup1 = [
            { slug: "comfort", name: "五感品質・素材", score: venue.scores.comfort },
            { slug: "silence", name: "静けさの再現", score: venue.scores.silence }
          ] %}
          {% for ax in axGroup1 %}
          <div class="flex items-center gap-4">
            <span class="text-xs text-muted w-36 shrink-0">{{ ax.name }}</span>
            <div class="axis-score-bar flex-1">
              <div class="axis-score-fill" style="width: {{ ax.score * 10 }}%"></div>
            </div>
            <span class="text-xs text-gold font-light w-6 text-right">{{ ax.score }}</span>
          </div>
          {% endfor %}
        </div>
      </div>

      {# 【心の核】心が動く #}
      <div>
        <p class="text-xs text-muted font-medium mb-3 tracking-wider">【心の核】心が動く</p>
        <div class="space-y-3">
          {% set axGroup2 = [
            { slug: "special", name: "特別感・ギフト体験", score: venue.scores.special },
            { slug: "story", name: "ストーリー継承", score: venue.scores.story }
          ] %}
          {% for ax in axGroup2 %}
          <div class="flex items-center gap-4">
            <span class="text-xs text-muted w-36 shrink-0">{{ ax.name }}</span>
            <div class="axis-score-bar flex-1">
              <div class="axis-score-fill" style="width: {{ ax.score * 10 }}%"></div>
            </div>
            <span class="text-xs text-gold font-light w-6 text-right">{{ ax.score }}</span>
          </div>
          {% endfor %}
        </div>
      </div>

      {# 【広がり】続く・伝わる・世界へ #}
      <div>
        <p class="text-xs text-muted font-medium mb-3 tracking-wider">【広がり】続く・伝わる・世界へ</p>
        <div class="space-y-3">
          {% set axGroup3 = [
            { slug: "revisit", name: "愛用・回遊価値", score: venue.scores.revisit },
            { slug: "record", name: "シェア・記録性", score: venue.scores.record },
            { slug: "inbound", name: "インバウンド適性", score: venue.scores.inbound }
          ] %}
          {% for ax in axGroup3 %}
          <div class="flex items-center gap-4">
            <span class="text-xs text-muted w-36 shrink-0">{{ ax.name }}</span>
            <div class="axis-score-bar flex-1">
              <div class="axis-score-fill" style="width: {{ ax.score * 10 }}%"></div>
            </div>
            <span class="text-xs text-gold font-light w-6 text-right">{{ ax.score }}</span>
          </div>
          {% endfor %}
        </div>
      </div>

    </div>
  </section>

  {# レーダーチャート（Platinum以上） #}
  {% if thisLevel >= 4 %}
  <section class="mb-14" data-aos="fade-up">
    <p class="label mb-6">7基準レーダーチャート</p>
    <div class="flex flex-col items-center gap-4">
      <div id="radar-chart-container" style="width:220px;height:220px;"></div>
      <div class="flex flex-wrap justify-center gap-x-4 gap-y-1">
        <span class="text-xs text-muted">五感品質 <strong class="text-gold">{{ venue.scores.comfort }}</strong></span>
        <span class="text-xs text-muted">静けさ <strong class="text-gold">{{ venue.scores.silence }}</strong></span>
        <span class="text-xs text-muted">特別感 <strong class="text-gold">{{ venue.scores.special }}</strong></span>
        <span class="text-xs text-muted">ストーリー <strong class="text-gold">{{ venue.scores.story }}</strong></span>
        <span class="text-xs text-muted">愛用価値 <strong class="text-gold">{{ venue.scores.revisit }}</strong></span>
        <span class="text-xs text-muted">記録性 <strong class="text-gold">{{ venue.scores.record }}</strong></span>
        <span class="text-xs text-muted">インバウンド <strong class="text-gold">{{ venue.scores.inbound }}</strong></span>
      </div>
    </div>
    <script>
    (function() {
      var scores = [{{ venue.scores.comfort }}, {{ venue.scores.silence }}, {{ venue.scores.special }}, {{ venue.scores.story }}, {{ venue.scores.revisit }}, {{ venue.scores.record }}, {{ venue.scores.inbound }}];
      var labels = ["五感品質", "静けさ", "特別感", "ストーリー", "愛用価値", "記録性", "インバウンド"];
      var cx = 110, cy = 110, r = 80, n = 7;
      var ns = "http://www.w3.org/2000/svg";
      var svg = document.createElementNS(ns, "svg");
      svg.setAttribute("viewBox", "0 0 220 220");
      svg.setAttribute("width", "220");
      svg.setAttribute("height", "220");
      svg.setAttribute("aria-hidden", "true");
      // Grid rings
      [2,4,6,8,10].forEach(function(lv) {
        var c = document.createElementNS(ns, "circle");
        c.setAttribute("cx", cx); c.setAttribute("cy", cy);
        c.setAttribute("r", r * lv / 10);
        c.setAttribute("fill", "none"); c.setAttribute("stroke", "#e5e0d8"); c.setAttribute("stroke-width", "0.5");
        svg.appendChild(c);
      });
      // Axis lines
      for (var i = 0; i < n; i++) {
        var ang = (Math.PI * 2 * i / n) - Math.PI / 2;
        var ln = document.createElementNS(ns, "line");
        ln.setAttribute("x1", cx); ln.setAttribute("y1", cy);
        ln.setAttribute("x2", (cx + r * Math.cos(ang)).toFixed(1));
        ln.setAttribute("y2", (cy + r * Math.sin(ang)).toFixed(1));
        ln.setAttribute("stroke", "#e5e0d8"); ln.setAttribute("stroke-width", "0.5");
        svg.appendChild(ln);
      }
      // Score polygon
      var pts = [];
      for (var i = 0; i < n; i++) {
        var ang = (Math.PI * 2 * i / n) - Math.PI / 2;
        var sr = r * scores[i] / 10;
        pts.push((cx + sr * Math.cos(ang)).toFixed(1) + "," + (cy + sr * Math.sin(ang)).toFixed(1));
      }
      var poly = document.createElementNS(ns, "polygon");
      poly.setAttribute("points", pts.join(" "));
      poly.setAttribute("fill", "rgba(184,150,12,0.15)");
      poly.setAttribute("stroke", "#B8960C"); poly.setAttribute("stroke-width", "1.5");
      svg.appendChild(poly);
      // Labels
      for (var i = 0; i < n; i++) {
        var ang = (Math.PI * 2 * i / n) - Math.PI / 2;
        var tx = cx + (r + 20) * Math.cos(ang);
        var ty = cy + (r + 20) * Math.sin(ang);
        var txt = document.createElementNS(ns, "text");
        txt.setAttribute("x", tx.toFixed(1)); txt.setAttribute("y", ty.toFixed(1));
        txt.setAttribute("text-anchor", "middle"); txt.setAttribute("dominant-baseline", "middle");
        txt.setAttribute("font-size", "8"); txt.setAttribute("fill", "#888");
        txt.textContent = labels[i];
        svg.appendChild(txt);
      }
      var container = document.getElementById("radar-chart-container");
      if (container) container.appendChild(svg);
    })();
    </script>
  </section>
  {% endif %}

  {# タグ（グレード別上限数） #}
  {% if venue.tags and venue.tags.length %}
  {%- set maxTagsMap = {"certified": 5, "silver": 10, "gold": 15, "platinum": 20, "flagship": 25} -%}
  {%- set tagLimit = maxTagsMap[venue.grade_slug] or 5 -%}
  <section class="mb-14" data-aos="fade-up">
    <p class="label mb-4">サードプレイス関連タグ</p>
    <div class="flex flex-wrap gap-2">
      {% for tag in venue.tags | head(tagLimit) %}
      <span class="text-xs px-3 py-1 border border-gold/30 rounded-full text-muted bg-white">{{ tag }}</span>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# 記事本文 #}
  <div class="prose" data-aos="fade-up">
    {{ content | safe }}
  </div>

  {# 施設紹介本文（venue.body） #}
  {% if venue.body %}
  <div class="prose mt-6" data-aos="fade-up">
    {{ venue.body | safe }}
  </div>
  {% endif %}

  {# FAQ（venue.faq） #}
  {% if venue.faq and venue.faq.length %}
  <section class="mt-14 mb-2" data-aos="fade-up">
    <p class="label mb-6">よくある質問</p>
    <div class="space-y-3">
      {% for item in venue.faq %}
      <details class="bg-white rounded-xl shadow-sm border border-border">
        <summary class="px-5 py-4 cursor-pointer text-sm font-normal list-none flex items-center justify-between gap-3" style="color:#3D2B1F;">
          <span>{{ item.q }}</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted shrink-0" aria-hidden="true"><path d="m6 9 6 6 6-6"/></svg>
        </summary>
        <div class="px-5 pb-4 text-sm text-muted leading-relaxed border-t border-border pt-3">
          {{ item.a }}
        </div>
      </details>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# 基本情報 #}
  <aside class="mt-16 pt-8 border-t border-border text-sm text-muted space-y-2" data-aos="fade-up">
    <p>{{ venue.area_primary.prefecture }} {{ venue.address }}</p>
    {% if venue.nearest_stations and venue.nearest_stations.length %}
    <p>最寄駅：{{ venue.nearest_stations | join("・") }}</p>
    {% endif %}
    {% if venue.opening_hours_display and venue.grade_slug != "select" %}
    <p>営業時間：{{ venue.opening_hours_display }}</p>
    {% endif %}
    {% if venue.price_range and venue.grade_slug != "select" %}
    <p>価格帯：{{ venue.price_range }}</p>
    {% endif %}
    <div class="flex flex-wrap gap-2 pt-2">
      {% if venue.url %}
      <a href="{{ venue.url }}" target="_blank" rel="noopener"
         class="inline-block border border-gold text-gold text-xs font-medium px-4 py-1.5 rounded-full hover:bg-gold hover:text-white transition-colors">関連サイト</a>
      {% endif %}
      {% if venue.instagram_url %}
      <a href="{{ venue.instagram_url }}" target="_blank" rel="noopener"
         class="inline-flex items-center gap-1.5 border border-border text-muted text-xs font-medium px-4 py-1.5 rounded-full hover:border-gold hover:text-gold transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        Instagram
      </a>
      {% endif %}
      {% if venue.telephone %}
      <a href="tel:{{ venue.telephone }}"
         class="inline-flex items-center gap-1.5 border border-border text-muted text-xs font-medium px-4 py-1.5 rounded-full hover:border-gold hover:text-gold transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.89 12.35 19.79 19.79 0 0 1 1.71 3.72 2 2 0 0 1 3.7 1.54h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l.87-.87a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        {{ venue.telephone }}
      </a>
      {% endif %}
      {% if venue.menu_url %}
      <a href="{{ venue.menu_url }}" target="_blank" rel="noopener"
         class="inline-block border border-border text-muted text-xs font-medium px-4 py-1.5 rounded-full hover:border-gold hover:text-gold transition-colors">メニュー</a>
      {% endif %}
      {% if venue.maps_url or venue.lat %}
      <a href="{% if venue.maps_url %}{{ venue.maps_url }}{% else %}https://maps.google.com/?q={{ venue.address }}{% endif %}" target="_blank" rel="noopener"
         class="inline-flex items-center gap-1.5 border border-border text-muted text-xs font-medium px-4 py-1.5 rounded-full hover:border-gold hover:text-gold transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
        地図を見る
      </a>
      {% endif %}
    </div>
    {% if venue.grade_slug == "select" %}
    <p class="pt-3 text-xs leading-relaxed" style="color:#3D2B1F;">営業日・営業時間・電話番号など店舗の詳細情報は変動することがあります。「地図を見る」から最新の店舗情報をご確認ください。</p>
    {% endif %}
    <p class="pt-2 text-xs">Third Place Japan {% if venue.grade_slug == "flagship" %}Flagship認定：{% else %}TPJセレクト掲載：{% endif %}{{ venue.certified_date }}</p>
  </aside>

  {# 同じ面（エリア×業種）のセレクト店舗 #}
  {% set hubVenues = venues | venuesByHub(
    venue.area_primary.prefecture_slug,
    venue.area_primary.city_slug,
    venue.area_primary.area_slug,
    venue.category_slug
  ) | rejectSlug(venue.slug) | sortByGrade %}
  {% if hubVenues.length %}
  <section class="mt-16 pt-10 border-t border-border" data-aos="fade-up">
    <div class="flex items-center justify-between mb-6">
      <p class="label">同じエリアの{{ venue.category }}</p>
      <a href="/stories/area/{{ venue.area_primary.prefecture_slug }}/{{ venue.area_primary.city_slug }}/{{ venue.area_primary.area_slug }}/{{ venue.category_slug }}/"
         class="text-xs text-muted hover:text-gold transition-colors">
        {{ venue.area_primary.area }}×{{ venue.category }}の面を見る →
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {% for v in hubVenues | head(4) %}
      <a href="/stories/select/{{ v.slug }}/"
         class="venue-card flex items-start gap-4 p-4 bg-white group">
        <div class="flex-1 min-w-0">
          <p class="font-serif text-sm font-light text-dark group-hover:text-gold transition-colors leading-snug truncate">
            {{ v.name }}
          </p>
          <p class="text-xs text-gold mt-1">{{ v.axes_primary }}</p>
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# 認証制度への還流導線 #}
  <div class="mt-16 pt-8 border-t border-border" data-aos="fade-up">
    {% if venue.grade_slug == "flagship" %}
    <div class="text-left md:text-center">
      <span class="inline-block text-xs font-medium tracking-wider text-gold border border-gold px-4 py-1.5 rounded-full mb-3">Flagship</span>
      <p class="text-sm text-muted">Third Place Japanの実証店舗として、理想の空間づくりを検証しています。</p>
      <p class="mt-3 flex items-center justify-start md:justify-center gap-4">
        <a href="{{ site.main_site_url }}/" class="text-gold hover:underline text-sm">TPJについて知る</a>
        <span class="text-border">·</span>
        <a href="/stories/about/certification-grades/" class="text-xs text-muted hover:text-gold transition-colors">グレードとは？</a>
      </p>
    </div>
    {% else %}
    <p class="text-sm text-muted text-left md:text-center">
      {% if venue.grade_slug == "platinum" %}Third Place Japan 認証店舗（Platinum）として掲載しています。
      {% elif venue.grade_slug == "gold" %}Third Place Japan 認証店舗（Gold）として掲載しています。
      {% elif venue.grade_slug == "silver" %}Third Place Japan 認証店舗（Silver）として掲載しています。
      {% elif venue.grade_slug == "certified" %}Third Place Japan 認証店舗（Certified）として掲載しています。
      {% else %}この場所は Third Place Japan セレクト店舗です。
      {% endif %}
      <br>
      <a href="{{ site.main_site_url }}/" class="text-muted hover:text-gold transition-colors text-xs">TPJについて知る</a>
      <span class="mx-2 text-border">·</span>
      <a href="/stories/about/certification-grades/" class="text-muted hover:text-gold transition-colors text-xs">グレードとは？</a>
    </p>
    {% endif %}
  </div>

  {# 英語版リンク #}
  {% if venue.has_en and lang != "en" %}
  <div class="mt-6 text-center">
    <a href="/en/stories/select/{{ venue.slug }}/" class="label hover:text-dark transition-colors">
      Read in English
    </a>
  </div>
  {% endif %}

</article>

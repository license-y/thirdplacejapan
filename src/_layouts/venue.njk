---
layout: stories.njk
og_type: "article"
---

{# グレード→数値マッピング #}
{%- set gradeNums = {"Certified": 1, "Silver": 2, "Gold": 3, "Platinum": 4, "Flagship": 5} -%}

{# LocalBusiness + 7軸スコア JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "{{ venue.name }}",
  "description": "{{ venue.citation | replace('"', '\\"') }}",
  "image": "{{ site.url }}{{ venue.image }}",
  "url": "{{ site.url }}/stories/certified/{{ venue.slug }}/",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "{{ venue.area_primary.area }}",
    "addressRegion": "{{ venue.area_primary.prefecture }}",
    "addressCountry": "JP"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": {{ venue.lat }},
    "longitude": {{ venue.lng }}
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".border-l-2"]
  },
  "additionalProperty": [
    { "@type": "PropertyValue", "name": "TPJ認証グレード", "value": "{{ venue.grade }}" },
    { "@type": "PropertyValue", "name": "TPJ認証取得日", "value": "{{ venue.certified_date }}" },
    { "@type": "PropertyValue", "name": "主評価軸", "value": "{{ venue.axes_primary }}" },
    { "@type": "PropertyValue", "name": "五感品質・素材スコア", "value": "{{ venue.scores.comfort }}/10" },
    { "@type": "PropertyValue", "name": "静けさの再現スコア", "value": "{{ venue.scores.silence }}/10" },
    { "@type": "PropertyValue", "name": "特別感・ギフト体験スコア", "value": "{{ venue.scores.special }}/10" },
    { "@type": "PropertyValue", "name": "ストーリー継承スコア", "value": "{{ venue.scores.story }}/10" },
    { "@type": "PropertyValue", "name": "再購入・回遊価値スコア", "value": "{{ venue.scores.revisit }}/10" },
    { "@type": "PropertyValue", "name": "シェア・記録性スコア", "value": "{{ venue.scores.record }}/10" },
    { "@type": "PropertyValue", "name": "インバウンド適性スコア", "value": "{{ venue.scores.inbound }}/10" }
  ]
}
</script>

{# Review + reviewRating JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Review",
  "itemReviewed": {
    "@type": "LocalBusiness",
    "name": "{{ venue.name | replace('"', '\\"') }}",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "{{ venue.area_primary.area }}",
      "addressRegion": "{{ venue.area_primary.prefecture }}",
      "addressCountry": "JP"
    }
  },
  "author": {
    "@type": "Organization",
    "name": "サードプレイスジャパン編集部",
    "url": "{{ site.url }}"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Third Place Japan",
    "url": "{{ site.url }}"
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": {{ gradeNums[venue.grade] or 1 }},
    "bestRating": 5,
    "worstRating": 1,
    "description": "TPJ認証グレード {{ venue.grade }}"
  },
  "reviewBody": "{{ venue.citation | replace('"', '\\"') }}",
  "url": "{{ site.url }}/stories/certified/{{ venue.slug }}/"
}
</script>

{# BreadcrumbList JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Third Place Japan", "item": "{{ site.url }}" },
    { "@type": "ListItem", "position": 2, "name": "Stories", "item": "{{ site.url }}/stories/" },
    { "@type": "ListItem", "position": 3, "name": "認証店舗", "item": "{{ site.url }}/stories/certified/" },
    { "@type": "ListItem", "position": 4, "name": "{{ venue.name }}", "item": "{{ site.url }}/stories/certified/{{ venue.slug }}/" }
  ]
}
</script>

<article class="max-w-2xl mx-auto px-6 py-16 md:py-24">

  {# パンくず #}
  <nav class="flex items-center gap-2 text-xs text-muted mb-12" aria-label="パンくず">
    <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
    <span class="text-border">／</span>
    <a href="/stories/certified/" class="hover:text-gold transition-colors">認証店舗</a>
    <span class="text-border">／</span>
    <span>{{ venue.name }}</span>
  </nav>

  {# グレードバッジ + カテゴリ #}
  <div class="flex items-center gap-4 mb-6" data-aos="fade-up">
    <span class="grade-badge">{{ venue.grade }}</span>
    <span class="label">{{ venue.category }}</span>
  </div>

  {# 店舗名 #}
  <h1 class="font-serif text-3xl md:text-4xl font-light text-dark mb-4 leading-tight" data-aos="fade-up">
    {{ venue.name }}
  </h1>

  {# エリア #}
  <p class="text-sm text-muted mb-10" data-aos="fade-up">
    <a href="/stories/area/{{ venue.area_primary.prefecture_slug }}/{{ venue.area_primary.city_slug }}/{{ venue.area_primary.area_slug }}/"
       class="hover:text-gold transition-colors">
      {{ venue.area_primary.prefecture }} {{ venue.area_primary.area }}
    </a>
    ·
    <a href="/stories/area/{{ venue.area_primary.prefecture_slug }}/{{ venue.area_primary.city_slug }}/{{ venue.area_primary.area_slug }}/{{ venue.category_slug }}/"
       class="hover:text-gold transition-colors">{{ venue.category }}</a>
  </p>

  {# 引用用一文（AEO核心・AIが引用する一文） #}
  <div class="border-l-2 border-gold pl-6 mb-12 py-1" data-aos="fade-up">
    <p class="font-serif text-base leading-relaxed text-dark">{{ venue.citation }}</p>
  </div>

  {# 空間の7基準スコア #}
  <section class="mb-14" data-aos="fade-up">
    <p class="label mb-6">空間の7基準</p>
    <div class="space-y-6">

      {# 【場の質】その場で感じる空間 #}
      <div>
        <p class="text-xs text-muted font-medium mb-3 tracking-wider">【場の質】その場で感じる空間</p>
        <div class="space-y-3">
          {% set axGroup1 = [
            { slug: "comfort", name: "五感品質・素材", score: venue.scores.comfort },
            { slug: "silence", name: "静けさの再現", score: venue.scores.silence }
          ] %}
          {% for ax in axGroup1 %}
          <div class="flex items-center gap-4">
            <span class="text-xs text-muted w-36 shrink-0">{{ ax.name }}</span>
            <div class="axis-score-bar flex-1">
              <div class="axis-score-fill" style="width: {{ ax.score * 10 }}%"></div>
            </div>
            <span class="text-xs text-gold font-light w-6 text-right">{{ ax.score }}</span>
          </div>
          {% endfor %}
        </div>
      </div>

      {# 【心の核】心が動く #}
      <div>
        <p class="text-xs text-muted font-medium mb-3 tracking-wider">【心の核】心が動く</p>
        <div class="space-y-3">
          {% set axGroup2 = [
            { slug: "special", name: "特別感・ギフト体験", score: venue.scores.special },
            { slug: "story", name: "ストーリー継承", score: venue.scores.story }
          ] %}
          {% for ax in axGroup2 %}
          <div class="flex items-center gap-4">
            <span class="text-xs text-muted w-36 shrink-0">{{ ax.name }}</span>
            <div class="axis-score-bar flex-1">
              <div class="axis-score-fill" style="width: {{ ax.score * 10 }}%"></div>
            </div>
            <span class="text-xs text-gold font-light w-6 text-right">{{ ax.score }}</span>
          </div>
          {% endfor %}
        </div>
      </div>

      {# 【広がり】続く・伝わる・世界へ #}
      <div>
        <p class="text-xs text-muted font-medium mb-3 tracking-wider">【広がり】続く・伝わる・世界へ</p>
        <div class="space-y-3">
          {% set axGroup3 = [
            { slug: "revisit", name: "再購入・回遊価値", score: venue.scores.revisit },
            { slug: "record", name: "シェア・記録性", score: venue.scores.record },
            { slug: "inbound", name: "インバウンド適性", score: venue.scores.inbound }
          ] %}
          {% for ax in axGroup3 %}
          <div class="flex items-center gap-4">
            <span class="text-xs text-muted w-36 shrink-0">{{ ax.name }}</span>
            <div class="axis-score-bar flex-1">
              <div class="axis-score-fill" style="width: {{ ax.score * 10 }}%"></div>
            </div>
            <span class="text-xs text-gold font-light w-6 text-right">{{ ax.score }}</span>
          </div>
          {% endfor %}
        </div>
      </div>

    </div>
  </section>

  {# 記事本文 #}
  <div class="prose" data-aos="fade-up">
    {{ content | safe }}
  </div>

  {# 基本情報 #}
  <aside class="mt-16 pt-8 border-t border-border text-sm text-muted space-y-2" data-aos="fade-up">
    <p>{{ venue.area_primary.prefecture }} {{ venue.address }}</p>
    {% if venue.nearest_stations and venue.nearest_stations.length %}
    <p>最寄駅：{{ venue.nearest_stations | join("・") }}</p>
    {% endif %}
    {% if venue.url %}
    <p><a href="{{ venue.url }}" target="_blank" rel="noopener" class="hover:text-gold transition-colors">公式サイト ↗</a></p>
    {% endif %}
    <p class="pt-2 text-xs">Third Place Japan TPJセレクト掲載：{{ venue.certified_date }}</p>
  </aside>

  {# 同じ面（エリア×業種）の認証店舗 #}
  {% set hubVenues = venues | venuesByHub(
    venue.area_primary.prefecture_slug,
    venue.area_primary.city_slug,
    venue.area_primary.area_slug,
    venue.category_slug
  ) | rejectSlug(venue.slug) | sortByGrade %}
  {% if hubVenues.length %}
  <section class="mt-16 pt-10 border-t border-border" data-aos="fade-up">
    <div class="flex items-center justify-between mb-6">
      <p class="label">同じエリアの{{ venue.category }}</p>
      <a href="/stories/area/{{ venue.area_primary.prefecture_slug }}/{{ venue.area_primary.city_slug }}/{{ venue.area_primary.area_slug }}/{{ venue.category_slug }}/"
         class="text-xs text-muted hover:text-gold transition-colors">
        {{ venue.area_primary.area }}×{{ venue.category }}の面を見る →
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {% for v in hubVenues | head(4) %}
      <a href="/stories/certified/{{ v.slug }}/"
         class="venue-card flex items-start gap-4 p-4 bg-white group">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1">
            <span class="grade-badge text-xs py-0.5 px-2">{{ v.grade }}</span>
          </div>
          <p class="font-serif text-sm font-light text-dark group-hover:text-gold transition-colors leading-snug truncate">
            {{ v.name }}
          </p>
          <p class="text-xs text-gold mt-1">{{ v.axes_primary }}</p>
        </div>
      </a>
      {% endfor %}
    </div>
  </section>
  {% endif %}

  {# 認証制度への還流導線 #}
  <div class="mt-16 pt-8 border-t border-border" data-aos="fade-up">
    <p class="text-sm text-muted text-left md:text-center">
      この場所は Third Place Japan 認証店舗です。<br class="hidden md:block">
      <a href="{{ site.main_site_url }}/certification/" class="text-gold hover:underline">認証制度について知る</a>
    </p>
  </div>

  {# 英語版リンク #}
  {% if venue.has_en and lang != "en" %}
  <div class="mt-6 text-center">
    <a href="/en/stories/certified/{{ venue.slug }}/" class="label hover:text-dark transition-colors">
      Read in English
    </a>
  </div>
  {% endif %}

</article>

<!doctype html>
<html lang="{{ lang or 'ja' }}">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% if title %}{{ title }} | {% endif %}Third Place Japan Stories</title>
  <meta name="description" content="{{ description or site.description }}">
  {% if keywords %}<meta name="keywords" content="{{ keywords }}">{% else %}<meta name="keywords" content="サードプレイス,第三の居場所,Third Place Japan,TPJ,認証,空間評価,カフェ,ホテル,日本">{% endif %}
  {% if canonical %}<link rel="canonical" href="{{ site.url }}{{ canonical }}">{% endif %}

  <!-- hreflang -->
  {% if hreflang_ja %}<link rel="alternate" hreflang="ja" href="{{ site.url }}{{ hreflang_ja }}">{% endif %}
  {% if hreflang_en %}<link rel="alternate" hreflang="en" href="{{ site.url }}{{ hreflang_en }}">{% endif %}
  {% if hreflang_ja and hreflang_en %}<link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ hreflang_ja }}">{% endif %}

  <!-- OGP -->
  <meta property="og:title" content="{% if title %}{{ title }} | {% endif %}Third Place Japan Stories">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:type" content="{{ og_type or 'website' }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}{% if og_image %}{{ og_image }}{% elif thumbnail %}{{ thumbnail }}{% else %}/assets/images/main/ogp.jpg{% endif %}">
  <meta property="og:locale" content="ja_JP">
  <meta property="og:site_name" content="Third Place Japan Stories">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{% if title %}{{ title }} | {% endif %}Third Place Japan Stories">
  <meta name="twitter:description" content="{{ description or site.description }}">
  <meta name="twitter:image" content="{{ site.url }}{% if og_image %}{{ og_image }}{% elif thumbnail %}{{ thumbnail }}{% else %}/assets/images/main/ogp.jpg{% endif %}">

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@300;400;500&family=Noto+Sans+JP:wght@300;400;500&display=swap" rel="stylesheet">

  <!-- Tailwind CSS v4 -->
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

  <!-- AOS -->
  <link rel="stylesheet" href="https://unpkg.com/aos@2.3.4/dist/aos.css">

  <!-- Lucide -->
  <script src="https://unpkg.com/lucide@0.536.0/dist/umd/lucide.js"></script>

  <style type="text/tailwindcss">
    @theme {
      --color-ivory: #F8F6F1;
      --color-dark: #1C1C1C;
      --color-dark2: #4A4A4A;
      --color-gold: #B8960C;
      --color-text: #2D2A26;
      --color-muted: #6B5C52;
      --color-border: #E4DDD6;
      --font-serif: 'Noto Serif JP', serif;
      --font-sans: 'Noto Sans JP', sans-serif;
    }
    body {
      font-family: var(--font-sans);
      color: var(--color-text);
      background-color: var(--color-ivory);
      -webkit-font-smoothing: antialiased;
    }
    .font-serif { font-family: var(--font-serif); }
    .gold-rule {
      width: 2rem;
      height: 1px;
      background: var(--color-gold);
    }
    .label {
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--color-gold);
      font-family: var(--font-sans);
    }
    .grade-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.25rem 0.85rem;
      border: 1px solid var(--color-gold);
      color: var(--color-gold);
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      border-radius: 9999px;
    }
    .axis-score-bar {
      height: 2px;
      background: var(--color-border);
      position: relative;
      overflow: hidden;
    }
    .axis-score-fill {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      background: var(--color-gold);
      transition: width 0.8s ease;
    }
    .venue-card {
      border-radius: 0.75rem;
      box-shadow: 0 1px 8px rgba(0,0,0,0.07);
      transition: box-shadow 0.2s ease;
    }
    .venue-card:hover {
      box-shadow: 0 6px 20px rgba(184,150,12,0.14);
    }
    .prose p { margin-bottom: 1.5em; line-height: 1.9; }
    .prose h2 {
      font-family: var(--font-serif);
      font-size: 1.25rem;
      font-weight: 400;
      margin-top: 2.5em;
      margin-bottom: 1em;
      padding-bottom: 0.5em;
      border-bottom: 1px solid var(--color-border);
    }
    .prose h3 {
      font-family: var(--font-serif);
      font-size: 1.1rem;
      font-weight: 400;
      margin-top: 2em;
      margin-bottom: 0.75em;
    }
  </style>

  <!-- JSON-LD: Organization -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Third Place Japan",
    "alternateName": ["TPJ", "サードプレイスジャパン"],
    "url": "{{ site.url }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site.url }}/assets/images/main/ogp.jpg"
    },
    "description": "{{ site.description }}",
    "areaServed": {
      "@type": "Country",
      "name": "Japan"
    }
  }
  </script>

  {% block head %}{% endblock %}
</head>
<body>
  {{ content | safe }}

  <!-- AOS init -->
  <script src="https://unpkg.com/aos@2.3.4/dist/aos.js"></script>
  <script>
    AOS.init({ duration: 700, easing: 'ease-out', once: true, offset: 40 });
  </script>
  <script>lucide.createIcons();</script>
  {% block scripts %}{% endblock %}
</body>
</html>

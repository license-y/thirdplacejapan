---
layout: stories.njk
og_type: "article"
---
{# hreflang: 自己参照＋対訳版への相互リンク（langフロントマターに応じて自己言語を判定）#}
<link rel="alternate" hreflang="{{ lang or 'ja' }}" href="{{ site.url }}{{ page.url }}">
{%- if lang == "en" -%}
{% if hreflang_ja %}<link rel="alternate" hreflang="ja" href="{{ site.url }}{{ hreflang_ja }}">
<link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ hreflang_ja }}">{% endif %}
{%- else -%}
{% if hreflang_en %}<link rel="alternate" hreflang="en" href="{{ site.url }}{{ hreflang_en }}">
<link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ page.url }}">{% endif %}
{%- endif %}

{# Article JSON-LD #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  {% set imgDim = thumbnail | imageDimensions %}
  "image": {
    "@type": "ImageObject",
    "url": "{{ site.url }}{{ thumbnail or '' }}",
    "width": {{ imgDim.width }},
    "height": {{ imgDim.height }}
  },
  "datePublished": "{{ date | dateISO }}",
  "dateModified": "{{ modified | dateISO if modified else date | dateISO }}",
  "author": {
    "@type": "Organization",
    "name": "サードプレイスジャパン編集部",
    "url": "{{ site.url }}",
    "description": "日本全国のサードプレイスを独自の7軸基準で評価・認証するThird Place Japan編集部。"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Third Place Japan",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site.url }}/assets/images/main/tpj-logo.png",
      "width": 900,
      "height": 275
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}{{ page.url }}"
  },
  "isPartOf": {
    "@type": "WebSite",
    "name": "Third Place Japan Stories",
    "url": "{{ site.url }}/stories/"
  },
  "inLanguage": "{{ lang or 'ja' }}",
  "about": {
    "@type": "Thing",
    "name": "サードプレイス"
  }{% set cleanKw = tags | cleanKeywords %}{% if cleanKw %},
  "keywords": "{{ cleanKw }}"{% endif %},
  "wordCount": {{ content | wordCount }},
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".answer-lead", ".faq-body p"]
  }
}
</script>

{# BreadcrumbList JSON-LD #}
{% set catObj = categories | findCategoryBySlug(category_slug) %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Third Place Japan",
      "item": "{{ site.url }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Stories",
      "item": "{{ site.url }}/stories/"
    }{% if category_slug == "about" %},
    {
      "@type": "ListItem",
      "position": 3,
      "name": "サードプレイスとは",
      "item": "{{ site.url }}/stories/about/"
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": {{ title | dump | safe }},
      "item": "{{ site.url }}{{ page.url }}"
    }{% elif catObj %},
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{ catObj.name_ja }}",
      "item": "{{ site.url }}/stories/{{ category_slug }}/"
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": {{ title | dump | safe }},
      "item": "{{ site.url }}{{ page.url }}"
    }{% else %},
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ title | dump | safe }},
      "item": "{{ site.url }}{{ page.url }}"
    }{% endif %}
  ]
}
</script>

{# FAQPage JSON-LD（Q&Aセクションがある場合）#}
{%- set faqItems = content | extractFAQ -%}
{% if faqItems.length %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in faqItems %}
    {
      "@type": "Question",
      "name": {{ item.q | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ item.a | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

<div class="max-w-6xl mx-auto px-6 py-10 md:py-16">
  <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_256px] gap-12 lg:gap-16 items-start">

    {# メインコンテンツ #}
    <article class="min-w-0">

      {# パンくず #}
      {% set catObj = categories | findCategoryBySlug(category_slug) %}
      <nav class="flex items-center gap-2 text-xs text-muted mb-12" aria-label="パンくず">
        <a href="/stories/" class="hover:text-gold transition-colors">Stories</a>
        {% if category_slug == "about" %}
        <span class="text-border">／</span>
        <a href="/stories/about/" class="hover:text-gold transition-colors">サードプレイスとは</a>
        {% elif catObj %}
        <span class="text-border">／</span>
        <a href="/stories/{{ category_slug }}/" class="hover:text-gold transition-colors">{{ catObj.name_ja }}</a>
        {% elif articleType == "feature" %}
        <span class="text-border">／</span>
        <a href="/stories/about/" class="hover:text-gold transition-colors">読み物</a>
        {% endif %}
        <span class="text-border">／</span>
        <span>{{ title }}</span>
      </nav>

      {# カテゴリラベル #}
      <div class="flex flex-wrap gap-2 mb-6" data-aos="fade-up">
        {% if category_slug == "about" %}
        <span class="label">サードプレイスとは</span>
        {% elif catObj %}
        <span class="label">{{ catObj.name_ja }}</span>
        {% else %}
        {% for tag in tags %}
        {% if tag != "articles" and tag != "feature" and tag != "story" %}
        <span class="label">{{ tag }}</span>
        {% endif %}
        {% endfor %}
        {% endif %}
      </div>

      {# タイトル #}
      <h1 class="font-serif text-3xl md:text-4xl font-light text-dark mb-6 leading-tight" data-aos="fade-up">
        {{ title }}
      </h1>

      {# 日付・著者・エリア（ピラー記事=aboutカテゴリは非表示）#}
      {% if date and category_slug != "about" %}
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1 mb-12 text-xs text-muted" data-aos="fade-up">
        <time datetime="{{ date | dateISO }}">{{ date | dateJa }}</time>
        <span>サードプレイスジャパン編集部</span>
        {% if area_slug %}
        {% set aInfo = area_slug | areaInfo %}
        {% if aInfo %}
        <span class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block opacity-60"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          <a href="{{ aInfo.prefUrl }}" class="hover:text-gold transition-colors">{{ aInfo.prefName }}</a>
          <span class="opacity-40">/</span>
          <a href="{{ aInfo.cityUrl }}" class="hover:text-gold transition-colors">{{ aInfo.cityName }}</a>
          <span class="opacity-40">/</span>
          <a href="{{ aInfo.areaUrl }}" class="hover:text-gold transition-colors font-medium text-dark">{{ aInfo.areaName }}</a>
        </span>
        {% endif %}
        {% elif area_name %}
        {% set cInfo = area_name | cityInfo %}
        {% if cInfo %}
        <span class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block opacity-60"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          <a href="{{ cInfo.prefUrl }}" class="hover:text-gold transition-colors">{{ cInfo.prefName }}</a>
          <span class="opacity-40">/</span>
          <a href="{{ cInfo.cityUrl }}" class="hover:text-gold transition-colors font-medium text-dark">{{ cInfo.cityName }}</a>
        </span>
        {% else %}
        <span class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="inline-block opacity-60"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          <span class="font-medium text-dark">{{ area_name }}</span>
        </span>
        {% endif %}
        {% endif %}
      </div>
      {% elif category_slug == "about" %}
      <div class="mb-12"></div>
      {% endif %}

      {# 定義スニペット #}
      {% if snippet %}
      <div class="answer-lead mb-10 px-6 py-5 border-l-2 border-gold" style="background-color: rgba(184,150,12,0.04);" data-aos="fade-up">
        <p class="text-sm text-dark leading-relaxed font-serif">{{ snippet }}</p>
      </div>
      {% endif %}

      {# サムネイル #}
      {% if thumbnail %}
      <div class="mb-12 rounded-xl overflow-hidden" data-aos="fade-up">
        <img src="{{ thumbnail }}" alt="{{ title }} | サードプレイスジャパン編集部" class="w-full aspect-video object-cover" loading="lazy" decoding="async">
      </div>
      {% endif %}

      {# 結論ファースト要約ブロック（AEO対応・snippet がない記事に自動表示）#}
      {% if not snippet and description %}
      <div class="answer-lead mb-10 px-5 py-4 rounded-xl" style="background-color: rgba(184,150,12,0.06); border-left: 2px solid #B8960C;" data-aos="fade-up">
        <p class="text-sm font-medium text-dark leading-relaxed">{{ description }}</p>
      </div>
      {% endif %}

      {# 本文 #}
      <div class="prose" data-pagefind-body data-aos="fade-up">
        {{ content | safe }}
      </div>

      {# シェアボタン #}
      {% set shareUrl = site.url + page.url %}
      <div class="mt-14 pt-10 border-t border-border" style="opacity:1;visibility:visible;">
        <p class="text-xs text-muted text-center mb-5">この記事をシェア</p>
        <div class="flex items-center justify-center gap-3 flex-wrap">
          <a href="https://twitter.com/intent/tweet?text={{ title | urlencode }}&url={{ shareUrl | urlencode }}"
             target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 border border-gold/30 px-5 py-2.5 text-xs text-text hover:border-gold hover:text-gold transition-all rounded-full bg-white shadow-sm hover:shadow-md">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.261 5.635 5.903-5.635zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            X ポスト
          </a>
          <a href="https://line.me/R/msg/text/?{{ title | urlencode }}%0D%0A{{ shareUrl | urlencode }}"
             target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 border border-gold/30 px-5 py-2.5 text-xs text-text hover:border-gold hover:text-gold transition-all rounded-full bg-white shadow-sm hover:shadow-md">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
            LINE
          </a>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shareUrl | urlencode }}"
             target="_blank" rel="noopener noreferrer"
             class="inline-flex items-center gap-2 border border-gold/30 px-5 py-2.5 text-xs text-text hover:border-gold hover:text-gold transition-all rounded-full bg-white shadow-sm hover:shadow-md">
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            Facebook
          </a>
        </div>
      </div>

    </article>

    {# サイドバー #}
    <aside class="hidden lg:block">
      <div class="sticky top-24 space-y-8">

        {# カテゴリ #}
        <div class="rounded-xl p-5" style="border:1px solid rgba(184,150,12,0.5);background-color:#ffffff;">
          <p class="label mb-4">カテゴリ</p>
          <ul class="space-y-0">
            {% for cat in categories %}
            <li class="border-b border-border last:border-0">
              <a href="/stories/{{ cat.slug }}/"
                 class="text-xs leading-snug block py-1.5 transition-colors
                 {% if cat.slug == category_slug %}text-gold font-medium{% else %}text-muted hover:text-gold{% endif %}">
                {{ cat.name_ja }}
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>

        {# 最新記事（現在のページと同じ言語のみ） #}
        {% set latestPosts = collections.articles | selectLang(lang or "ja") | rejectCategory("about") | head(5) %}
        {% if latestPosts and latestPosts.length %}
        <div class="rounded-xl p-5" style="border:1px solid rgba(184,150,12,0.5);background-color:#ffffff;">
          <p class="label mb-4">{{ "Latest Articles" if lang == "en" else "最新記事" }}</p>
          <ul class="space-y-4">
            {% for post in latestPosts %}
            <li>
              <a href="{{ post.url }}" class="group block">
                {% set postCat = categories | findCategoryBySlug(post.data.category_slug) %}
                {% if postCat %}
                <p class="text-xs text-gold mb-0.5">{{ postCat.name_en if lang == "en" else postCat.name_ja }}</p>
                {% elif post.data.category_slug == "about" %}
                <p class="text-xs text-gold mb-0.5">{{ "What Is a Third Place" if lang == "en" else "サードプレイスとは" }}</p>
                {% endif %}
                <p class="text-xs text-text group-hover:text-gold transition-colors leading-snug">{{ post.data.title }}</p>
                <p class="text-xs text-muted mt-1">{{ post.date | dateJa }}</p>
              </a>
            </li>
            {% endfor %}
          </ul>
        </div>
        {% endif %}

        {# サードプレイスとは #}
        {% if collections.aboutArticles and collections.aboutArticles.length %}
        <div class="rounded-xl p-5" style="border:1px solid rgba(184,150,12,0.5);background-color:#ffffff;">
          <p class="label mb-4">サードプレイスとは</p>
          <ul class="space-y-0">
            {% for post in collections.aboutArticles | head(5) %}
            <li class="border-b border-border last:border-0">
              <a href="{{ post.url }}" class="text-xs text-muted hover:text-gold transition-colors leading-snug block py-1.5">
                {{ post.data.title }}
              </a>
            </li>
            {% endfor %}
          </ul>
          <a href="/stories/about/" class="text-xs text-muted hover:text-gold transition-colors mt-3 block">すべて見る →</a>
        </div>
        {% endif %}

      </div>
    </aside>

  </div>

  {# 関連記事（現在のページと同じ言語のみ） #}
  {% set relatedArticles = collections.articles | selectLang(lang or "ja") | relatedPostsByCat(page.url, category_slug, 3) %}
  {% if relatedArticles and relatedArticles.length %}
  <div class="mt-16 pt-12 border-t border-border" style="opacity:1;visibility:visible;">
    <div class="flex items-center gap-2 mb-8">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted shrink-0" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
      <p class="label">関連記事</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {% for post in relatedArticles %}
      <a href="{{ post.url }}" class="group block bg-white rounded-xl overflow-hidden border border-gold/30 hover:border-gold shadow-sm hover:shadow-md transition-all">
        {% if post.data.thumbnail %}
        <div class="h-28 overflow-hidden">
          <img src="{{ post.data.thumbnail }}" alt="{{ post.data.title }}"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
               loading="lazy" decoding="async">
        </div>
        {% else %}
        <div class="h-28" style="background-color: #f0ede6;"></div>
        {% endif %}
        <div class="p-4">
          {% if post.data.category_slug == "about" %}
          <p class="text-xs text-muted mb-1">サードプレイスとは</p>
          {% else %}
          {% set relCat = categories | findCategoryBySlug(post.data.category_slug) %}
          {% if relCat %}<p class="text-xs text-muted mb-1">{{ relCat.name_ja }}</p>{% endif %}
          {% endif %}
          <h3 class="text-sm font-light text-dark group-hover:text-gold transition-colors leading-snug" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">{{ post.data.title }}</h3>
          <p class="text-xs text-muted mt-2">{{ post.date | dateJa }}</p>
        </div>
      </a>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {# 前の記事・次の記事（現在のページと同じ言語のみ） #}
  {% set langArticles = collections.articles | selectLang(lang or "ja") %}
  {% set prevArticle = langArticles | prevPost(page.url) %}
  {% set nextArticle = langArticles | nextPost(page.url) %}
  {% if prevArticle or nextArticle %}
  <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-4" style="opacity:1;visibility:visible;">
    <div>
      {% if prevArticle %}
      <a href="{{ prevArticle.url }}" class="group flex items-center gap-3 rounded-xl p-4 h-full border border-gold/30 hover:border-gold shadow-sm hover:shadow-md transition-all bg-white">
        {% if prevArticle.data.thumbnail %}
        <div class="shrink-0 w-16 h-16 rounded-lg overflow-hidden bg-border">
          <img src="{{ prevArticle.data.thumbnail }}" alt="{{ prevArticle.data.title }}"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
               loading="lazy" decoding="async">
        </div>
        {% endif %}
        <div class="min-w-0">
          <p class="text-xs text-muted mb-1">‹ 前の記事</p>
          <p class="text-sm text-dark group-hover:text-gold transition-colors leading-snug" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{{ prevArticle.data.title }}</p>
        </div>
      </a>
      {% endif %}
    </div>
    <div>
      {% if nextArticle %}
      <a href="{{ nextArticle.url }}" class="group flex items-center gap-3 rounded-xl p-4 h-full border border-gold/30 hover:border-gold shadow-sm hover:shadow-md transition-all bg-white">
        <div class="min-w-0 flex-1 text-right">
          <p class="text-xs text-muted mb-1">次の記事 ›</p>
          <p class="text-sm text-dark group-hover:text-gold transition-colors leading-snug" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{{ nextArticle.data.title }}</p>
        </div>
        {% if nextArticle.data.thumbnail %}
        <div class="shrink-0 w-16 h-16 rounded-lg overflow-hidden bg-border">
          <img src="{{ nextArticle.data.thumbnail }}" alt="{{ nextArticle.data.title }}"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
               loading="lazy" decoding="async">
        </div>
        {% endif %}
      </a>
      {% endif %}
    </div>
  </div>
  {% endif %}

</div>
